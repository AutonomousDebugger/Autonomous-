    applyCorner(sendBtn, THEME.cornerRBtn)

    sendBtn.MouseEnter:Connect(function()
        tween(sendBtn, {BackgroundColor3 = THEME.accentGlow}, THEME.tweenQuick)
        tween(sendBtn, {Size = UDim2.new(0, 42, 0, 38)}, THEME.tweenQuick)
    end)
    sendBtn.MouseLeave:Connect(function()
        tween(sendBtn, {BackgroundColor3 = THEME.accent}, THEME.tweenQuick)
        tween(sendBtn, {Size = UDim2.new(0, 40, 0, 36)}, THEME.tweenQuick)
    end)

    -- Bottom status bar
    local statusBar = Instance.new("Frame")
    statusBar.Name                  = "StatusBar"
    statusBar.Size                  = UDim2.new(1, -16, 0, 28)
    statusBar.Position              = UDim2.new(0, 8, 0, 70)
    statusBar.BackgroundTransparency = 1
    statusBar.Parent                = chatOuter

    local statusText = createLabel("Ready", 11, THEME.textMuted, statusBar)
    statusText.Size = UDim2.new(0.6, 0, 1, 0)
    statusText.Font = Enum.Font.Gotham
    self._statusText = statusText

    local charCount = createLabel("0 / 500", 11, THEME.textMuted, statusBar)
    charCount.Size             = UDim2.new(0.4, 0, 1, 0)
    charCount.Position         = UDim2.new(0.6, 0, 0, 0)
    charCount.TextXAlignment   = Enum.TextXAlignment.Right
    charCount.Font             = Enum.Font.Gotham
    self._charCount = charCount

    -- input char counter + enter-to-send
    inputBox:GetPropertyChangedSignal("Text"):Connect(function()
        local len = utf8.len(inputBox.Text) or 0
        charCount.Text = len .. " / 500"
        if len > 500 then
            inputBox.Text = inputBox.Text:sub(1, 500)
        end
    end)

    local function sendMessage()
        local txt = inputBox.Text:match("^%s*(.-)%s*$")
        if txt == "" then return end
        inputBox.Text = ""
        self:_onSend(txt)
    end

    sendBtn.MouseButton1Click:Connect(sendMessage)
    sendBtn.TouchTap:Connect(sendMessage)

    -- Enter key to send (but Shift+Enter is newline on desktop)
    UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if input.KeyCode == Enum.KeyCode.Return and not UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
            if inputBox:IsFocused() then
                sendMessage()
            end
        end
    end)

    -- ── REOPEN BUTTON ──────────────────────────────────────────────────────
    local reopenBtn = Instance.new("TextButton")
    reopenBtn.Name             = "ReopenBtn"
    reopenBtn.Size             = UDim2.new(0, isMobile() and 52 or 44, 0, isMobile() and 52 or 44)
    reopenBtn.Position         = UDim2.new(0, 16, 1, -(isMobile() and 72 or 60))
    reopenBtn.BackgroundColor3 = THEME.accent
    reopenBtn.Text             = ICONS.reopen
    reopenBtn.TextColor3       = Color3.fromRGB(255, 255, 255)
    reopenBtn.Font             = Enum.Font.GothamBold
    reopenBtn.TextSize         = 20
    reopenBtn.Visible          = false
    reopenBtn.BorderSizePixel  = 0
    reopenBtn.ZIndex           = 10
    reopenBtn.Parent           = sg
    applyCorner(reopenBtn, UDim.new(1, 0))
    applyStroke(reopenBtn, THEME.accentGlow, 1.5)

    -- pulse animation on reopen
    local pulsing = false
    local function startPulse()
        if pulsing then return end
        pulsing = true
        RunService.Heartbeat:Connect(function()
            if not pulsing then return end
            local t = tick()
            local s = 0.92 + 0.08 * math.sin(t * 3)
            reopenBtn.Size = UDim2.new(0, math.floor((isMobile() and 52 or 44)*s), 0, math.floor((isMobile() and 52 or 44)*s))
        end)
    end

    reopenBtn.MouseButton1Click:Connect(function() self:Open() end)
    reopenBtn.TouchTap:Connect(function() self:Open() end)

    self._reopenBtn = reopenBtn
    self._startPulse = startPulse

    -- ── THINKING INDICATOR (future AI slot) ────────────────────────────────
    local thinkRow = Instance.new("Frame")
    thinkRow.Name                  = "ThinkingRow"
    thinkRow.Size                  = UDim2.new(1, -16, 0, 24)
    thinkRow.Position              = UDim2.new(0, 8, 0, 0)
    thinkRow.BackgroundTransparency = 1
    thinkRow.Visible               = false
    thinkRow.LayoutOrder           = 99
    thinkRow.Parent                = logScroll

    local thinkDots = createLabel("● ● ●  Thinking...", 11, THEME.accentGlow, thinkRow)
    thinkDots.Size = UDim2.new(1, 0, 1, 0)
    thinkDots.Font = Enum.Font.GothamBold
    self._thinkRow = thinkRow

    -- Animate dots
    RunService.Heartbeat:Connect(function()
        if self._isThinking then
            local t = tick() * 2
            local dots = { "●  ○  ○", "●  ●  ○", "●  ●  ●", "○  ●  ●", "○  ○  ●", "○  ○  ○" }
            thinkDots.Text = (dots[math.floor(t % #dots) + 1] or dots[1]) .. "  AI is thinking..."
        end
    end)

    -- ── ENTRANCE ANIMATION ─────────────────────────────────────────────────
    win.Size             = UDim2.new(0, self.width, 0, 0)
    win.BackgroundTransparency = 1
    tween(win, {
        Size               = UDim2.new(0, self.width, 0, self.height),
        BackgroundTransparency = 0,
    }, THEME.tweenBounce)
end

-- ─────────────────────────────────────────────────────────────────────────────
--  INTERNAL: handle send
-- ─────────────────────────────────────────────────────────────────────────────
function NexusUI:_onSend(text)
    self:Log(text, "user")
    self:_setStatus("Sending...")

    if self._messageCallback then
        -- Call in coroutine so UI doesn't freeze
        coroutine.wrap(function()
            local ok, err = pcall(self._messageCallback, text)
            if not ok then
                self:Log("Error: " .. tostring(err), "err")
            end
            self:_setStatus("Ready")
        end)()
    else
        self:_setStatus("Ready  (no handler set)")
    end
end

function NexusUI:_setStatus(msg)
    if self._statusText then
        self._statusText.Text = msg
    end
end

-- ─────────────────────────────────────────────────────────────────────────────
--  PUBLIC API
-- ─────────────────────────────────────────────────────────────────────────────

-- :Log(text, logType)
-- logType: "system" | "user" | "bot" | "warn" | "err"
function NexusUI:Log(text, logType)
    logType = logType or "system"
    local ts = os.date("%H:%M:%S")

    table.insert(self._logEntries, { text = text, logType = logType, timestamp = ts })

    -- Trim old entries if over max
    if #self._logEntries > self.maxLogs then
        local oldest = self._logScroll:FindFirstChild("LogEntry")
        if oldest then oldest:Destroy() end
        table.remove(self._logEntries, 1)
    end

    -- Hide thinking row while building entry
    self._thinkRow.Visible    = false
    self._thinkRow.LayoutOrder = 9999

    local entry = buildLogEntry(self._logScroll, {
        text      = text,
        logType   = logType,
        timestamp = ts,
    })
    entry.LayoutOrder = #self._logEntries

    -- Auto-scroll to bottom
    task.defer(function()
        self._logScroll.CanvasPosition = Vector2.new(0, math.huge)
    end)
end

-- :OnMessage(callback)  callback(text: string)
function NexusUI:OnMessage(callback)
    self._messageCallback = callback
end

-- :SetAIHandler(fn)  — future: plug in AI stream here
function NexusUI:SetAIHandler(fn)
    self._aiHandler = fn
end

-- :SetTitle(title, subtitle)
function NexusUI:SetTitle(title, subtitle)
    self.title = title or self.title
    if self._titleLbl then
        self._titleLbl.Text = self.title
    end
end

-- :SetStatus(msg)  — update the bottom status bar
function NexusUI:SetStatus(msg)
    self:_setStatus(msg)
end

-- :SetThinking(bool)  — future AI: show animated typing indicator
function NexusUI:SetThinking(state)
    self._isThinking         = state
    self._thinkRow.Visible   = state
    self._thinkRow.LayoutOrder = state and (#self._logEntries + 1) or 9999
    task.defer(function()
        self._logScroll.CanvasPosition = Vector2.new(0, math.huge)
    end)
end

-- :SetOnlineStatus(online: bool)
function NexusUI:SetOnlineStatus(online)
    if self._statusDot then
        self._statusDot.BackgroundColor3 = online
            and Color3.fromRGB(80, 255, 150)
            or  Color3.fromRGB(255, 80, 80)
    end
end

-- :ClearLogs()
function NexusUI:ClearLogs()
    self._logEntries = {}
    for _, child in ipairs(self._logScroll:GetChildren()) do
        if child:IsA("Frame") and child.Name == "LogEntry" then
            child:Destroy()
        end
    end
end

-- :Close()
function NexusUI:Close()
    if not self._isOpen then return end
    self._isOpen = false

    tween(self._win, {
        Size = UDim2.new(0, self._win.Size.X.Offset, 0, 0),
        BackgroundTransparency = 1,
    }, THEME.tweenMed)

    task.delay(0.35, function()
        self._win.Visible = false
        self._reopenBtn.Visible = true
        self._startPulse()
    end)
end

-- :Open()
function NexusUI:Open()
    if self._isOpen then return end
    self._isOpen = true

    self._reopenBtn.Visible = false
    self._win.Visible       = true
    self._win.Size          = UDim2.new(0, self.width, 0, 0)
    self._win.BackgroundTransparency = 1

    tween(self._win, {
        Size = UDim2.new(0, self.width, 0, self.height),
        BackgroundTransparency = 0,
    }, THEME.tweenBounce)
end

-- :Destroy()
function NexusUI:Destroy()
    if self._sg then
        self._sg:Destroy()
    end
    self._logEntries = {}
end

-- ─────────────────────────────────────────────────────────────────────────────
--  RETURN LIBRARY
-- ─────────────────────────────────────────────────────────────────────────────
return NexusUI

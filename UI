    header.BorderSizePixel  = 0
    header.ZIndex           = 3
    header.Parent           = win

    applyGradient(header,
        ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(30, 34, 52)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(20, 22, 34)),

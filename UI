-- AutonomousUI Library
-- Load via: local AutonomousUI = loadstring(game:HttpGet("https://raw.githubusercontent.com/AutonomousDebugger/Autonomous-/refs/heads/main/UI"))()
-- Version: 1.0.2

local AutonomousUI = {}
AutonomousUI.__index = AutonomousUI

local Players          = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local TweenService     = game:GetService("TweenService")

local LocalPlayer = Players.LocalPlayer
local PlayerGui   = LocalPlayer:WaitForChild("PlayerGui")

-- ─── Theme ───────────────────────────────────────────────────
local THEME = {
	Background    = Color3.fromRGB(28, 28, 31),
	Surface       = Color3.fromRGB(36, 36, 40),
	SurfaceLight  = Color3.fromRGB(46, 46, 52),
	Border        = Color3.fromRGB(58, 58, 68),
	Accent        = Color3.fromRGB(100, 100, 210),
	AccentDim     = Color3.fromRGB(60,  60,  150),
	AccentHover   = Color3.fromRGB(120, 120, 230),
	TextPrimary   = Color3.fromRGB(228, 228, 234),
	TextSecondary = Color3.fromRGB(148, 148, 158),
	TextMuted     = Color3.fromRGB(90,  90,  105),
	Success       = Color3.fromRGB(72,  196, 110),
	Warning       = Color3.fromRGB(218, 165, 50),
	Error         = Color3.fromRGB(218, 72,  72),
	Info          = Color3.fromRGB(72,  155, 218),
}

-- Window dimensions (compact)
local WIN_W  = 290
local WIN_H  = 390
local WIN_TW = TweenInfo.new(0.22, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
local T_FAST = TweenInfo.new(0.12, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
local T_MED  = TweenInfo.new(0.22, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)

-- ─── Helpers ─────────────────────────────────────────────────
local function tw(obj, info, props)
	TweenService:Create(obj, info, props):Play()
end

local function pad(f, t, r, b, l)
	local p = Instance.new("UIPadding")
	p.PaddingTop    = UDim.new(0, t or 6)
	p.PaddingRight  = UDim.new(0, r or 6)
	p.PaddingBottom = UDim.new(0, b or 6)
	p.PaddingLeft   = UDim.new(0, l or 6)
	p.Parent = f; return p
end

local function corner(f, r)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, r or 8)
	c.Parent = f; return c
end

local function stroke(f, col, th, tr)
	local s = Instance.new("UIStroke")
	s.Color = col or THEME.Border
	s.Thickness = th or 1
	s.Transparency = tr or 0
	s.Parent = f; return s
end

local function label(parent, text, sz, col, xa)
	local l = Instance.new("TextLabel")
	l.Text = text or ""
	l.TextSize = sz or 12
	l.TextColor3 = col or THEME.TextPrimary
	l.TextXAlignment = xa or Enum.TextXAlignment.Left
	l.Font = Enum.Font.GothamMedium
	l.BackgroundTransparency = 1
	l.Size = UDim2.new(1, 0, 0, (sz or 12) + 4)
	l.Parent = parent; return l
end

local function button(parent, text, sz)
	local b = Instance.new("TextButton")
	b.Text = text or ""
	b.TextSize = sz or 12
	b.TextColor3 = THEME.TextPrimary
	b.Font = Enum.Font.GothamMedium
	b.BackgroundTransparency = 1
	b.AutoButtonColor = false
	b.Size = UDim2.new(1, 0, 1, 0)
	b.Parent = parent; return b
end

-- ─── Drag (PC + Mobile) ──────────────────────────────────────
local function enableDrag(handle, frame)
	local dragging, dragInput, startPos, startFPos

	handle.InputBegan:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1
			or inp.UserInputType == Enum.UserInputType.Touch then
			dragging  = true
			startPos  = inp.Position
			startFPos = frame.Position
			inp.Changed:Connect(function()
				if inp.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	handle.InputChanged:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseMovement
			or inp.UserInputType == Enum.UserInputType.Touch then
			dragInput = inp
		end
	end)

	UserInputService.InputChanged:Connect(function(inp)
		if dragging and inp == dragInput then
			local d = inp.Position - startPos
			frame.Position = UDim2.new(
				startFPos.X.Scale, startFPos.X.Offset + d.X,
				startFPos.Y.Scale, startFPos.Y.Offset + d.Y
			)
		end
	end)
end

-- ─── Constructor ─────────────────────────────────────────────
function AutonomousUI.new(config)
	config = config or {}

	local self       = setmetatable({}, AutonomousUI)
	self._logs       = {}
	self._messages   = {}
	self._isOpen     = true
	self._activeTab  = "Chat"
	self._version    = "1.0.2"

	-- ScreenGui
	local sg = Instance.new("ScreenGui")
	sg.Name           = "AutonomousUI"
	sg.ResetOnSpawn   = false
	sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	sg.IgnoreGuiInset = true
	sg.DisplayOrder   = 999
	sg.Parent         = PlayerGui
	self._screenGui   = sg

	-- ── Main Window ──────────────────────────────────────────
	local win = Instance.new("Frame")
	win.Name             = "Window"
	win.Size             = UDim2.new(0, WIN_W, 0, WIN_H)
	win.Position         = UDim2.new(0.5, -WIN_W/2, 0.5, -WIN_H/2)
	win.BackgroundColor3 = THEME.Background
	win.BorderSizePixel  = 0
	win.ClipsDescendants = true
	win.Parent           = sg
	corner(win, 10)
	stroke(win, THEME.Border, 1)
	self._window = win

	-- subtle inner glow line at top
	local topGlow = Instance.new("Frame")
	topGlow.Size             = UDim2.new(1, 0, 0, 1)
	topGlow.BackgroundColor3 = THEME.Accent
	topGlow.BackgroundTransparency = 0.6
	topGlow.BorderSizePixel  = 0
	topGlow.ZIndex           = 5
	topGlow.Parent           = win

	-- ── Title Bar (40px) ─────────────────────────────────────
	local titleBar = Instance.new("Frame")
	titleBar.Name             = "TitleBar"
	titleBar.Size             = UDim2.new(1, 0, 0, 40)
	titleBar.BackgroundColor3 = THEME.Surface
	titleBar.BorderSizePixel  = 0
	titleBar.ZIndex           = 2
	titleBar.Parent           = win
	-- square bottom edge (win clips it)
	corner(titleBar, 10)

	-- bottom fill to square off titlebar bottom
	local tbFill = Instance.new("Frame")
	tbFill.Size             = UDim2.new(1, 0, 0, 10)
	tbFill.Position         = UDim2.new(0, 0, 1, -10)
	tbFill.BackgroundColor3 = THEME.Surface
	tbFill.BorderSizePixel  = 0
	tbFill.Parent           = titleBar

	local divider = Instance.new("Frame")
	divider.Size             = UDim2.new(1, 0, 0, 1)
	divider.Position         = UDim2.new(0, 0, 1, -1)
	divider.BackgroundColor3 = THEME.Border
	divider.BorderSizePixel  = 0
	divider.Parent           = titleBar

	-- Pulse dot
	local dot = Instance.new("Frame")
	dot.Size             = UDim2.new(0, 7, 0, 7)
	dot.Position         = UDim2.new(0, 12, 0.5, -3)
	dot.BackgroundColor3 = THEME.Accent
	dot.BorderSizePixel  = 0
	dot.Parent           = titleBar
	corner(dot, 99)
	tw(dot, TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true),
		{ BackgroundColor3 = THEME.AccentDim })

	-- Title text
	local titleLbl = label(titleBar, "Autonomous", 13, THEME.TextPrimary, Enum.TextXAlignment.Left)
	titleLbl.Font     = Enum.Font.GothamBold
	titleLbl.Size     = UDim2.new(1, -90, 1, 0)
	titleLbl.Position = UDim2.new(0, 26, 0, 0)
	titleLbl.TextSize = 13

	-- Version tag
	local verLbl = label(titleBar, "v" .. self._version, 9, THEME.TextMuted, Enum.TextXAlignment.Left)
	verLbl.Size     = UDim2.new(0, 40, 1, 0)
	verLbl.Position = UDim2.new(0, 26 + 80, 0, 0)

	-- ── Close Button ─────────────────────────────────────────
	-- Styled as a red pill with an X drawn from two rotated frames
	local closeHolder = Instance.new("Frame")
	closeHolder.Size             = UDim2.new(0, 26, 0, 26)
	closeHolder.Position         = UDim2.new(1, -34, 0.5, -13)
	closeHolder.BackgroundColor3 = Color3.fromRGB(55, 36, 36)
	closeHolder.BorderSizePixel  = 0
	closeHolder.Parent           = titleBar
	corner(closeHolder, 6)
	stroke(closeHolder, Color3.fromRGB(100, 40, 40), 1)

	-- X lines drawn as two thin frames rotated 45 deg
	local function makeLine(parent, angle)
		local f = Instance.new("Frame")
		f.Size                  = UDim2.new(0, 12, 0, 2)
		f.Position              = UDim2.new(0.5, -6, 0.5, -1)
		f.BackgroundColor3      = Color3.fromRGB(220, 80, 80)
		f.BorderSizePixel       = 0
		f.Rotation              = angle
		f.Parent                = parent
		corner(f, 2)
		return f
	end
	makeLine(closeHolder, 45)
	makeLine(closeHolder, -45)

	-- invisible button overlay
	local closeBtn = Instance.new("TextButton")
	closeBtn.Size                 = UDim2.new(1, 0, 1, 0)
	closeBtn.BackgroundTransparency = 1
	closeBtn.Text                 = ""
	closeBtn.AutoButtonColor      = false
	closeBtn.Parent               = closeHolder
	self._closeBtn = closeBtn

	-- hover brighten
	closeBtn.MouseEnter:Connect(function()
		tw(closeHolder, T_FAST, { BackgroundColor3 = Color3.fromRGB(80, 36, 36) })
	end)
	closeBtn.MouseLeave:Connect(function()
		tw(closeHolder, T_FAST, { BackgroundColor3 = Color3.fromRGB(55, 36, 36) })
	end)

	enableDrag(titleBar, win)

	-- ── Tab Bar (32px) ────────────────────────────────────────
	local tabBar = Instance.new("Frame")
	tabBar.Name             = "TabBar"
	tabBar.Size             = UDim2.new(1, 0, 0, 32)
	tabBar.Position         = UDim2.new(0, 0, 0, 40)
	tabBar.BackgroundColor3 = THEME.Surface
	tabBar.BorderSizePixel  = 0
	tabBar.Parent           = win

	local tabDiv = Instance.new("Frame")
	tabDiv.Size             = UDim2.new(1, 0, 0, 1)
	tabDiv.Position         = UDim2.new(0, 0, 1, -1)
	tabDiv.BackgroundColor3 = THEME.Border
	tabDiv.BorderSizePixel  = 0
	tabDiv.Parent           = tabBar

	local tabList = Instance.new("UIListLayout")
	tabList.FillDirection = Enum.FillDirection.Horizontal
	tabList.SortOrder     = Enum.SortOrder.LayoutOrder
	tabList.Parent        = tabBar

	self._tabs      = {}
	self._tabFrames = {}

	-- ── Content Area ─────────────────────────────────────────
	-- 40 title + 32 tab + 42 input = 114; content fills the rest
	local contentArea = Instance.new("Frame")
	contentArea.Name                  = "ContentArea"
	contentArea.Size                  = UDim2.new(1, 0, 1, -114)
	contentArea.Position              = UDim2.new(0, 0, 0, 72)
	contentArea.BackgroundTransparency = 1
	contentArea.ClipsDescendants      = true
	contentArea.Parent                = win
	self._contentArea = contentArea

	-- ── Reopen Pill ──────────────────────────────────────────
	local reopenPill = Instance.new("Frame")
	reopenPill.Name             = "ReopenPill"
	reopenPill.Size             = UDim2.new(0, 120, 0, 30)
	reopenPill.Position         = UDim2.new(0, 14, 1, -44)
	reopenPill.BackgroundColor3 = THEME.Surface
	reopenPill.BorderSizePixel  = 0
	reopenPill.Visible          = false
	reopenPill.Parent           = sg
	corner(reopenPill, 20)
	stroke(reopenPill, THEME.Accent, 1)
	enableDrag(reopenPill, reopenPill)

	local rpDot = Instance.new("Frame")
	rpDot.Size             = UDim2.new(0, 6, 0, 6)
	rpDot.Position         = UDim2.new(0, 10, 0.5, -3)
	rpDot.BackgroundColor3 = THEME.Accent
	rpDot.BorderSizePixel  = 0
	rpDot.Parent           = reopenPill
	corner(rpDot, 99)

	local reopenBtn = button(reopenPill, "Autonomous", 11)
	reopenBtn.TextXAlignment = Enum.TextXAlignment.Center
	reopenBtn.TextColor3     = THEME.TextPrimary
	self._reopenBtn = reopenPill

	-- ── Build Tabs ────────────────────────────────────────────
	local TAB_NAMES = {"Chat", "Logs"}

	for i, name in ipairs(TAB_NAMES) do
		local tabHolder = Instance.new("Frame")
		tabHolder.Size                  = UDim2.new(0, 72, 1, 0)
		tabHolder.BackgroundTransparency = 1
		tabHolder.LayoutOrder           = i
		tabHolder.Parent                = tabBar

		local indicator = Instance.new("Frame")
		indicator.Size                   = UDim2.new(0.65, 0, 0, 2)
		indicator.Position               = UDim2.new(0.175, 0, 1, -1)
		indicator.BackgroundColor3       = THEME.Accent
		indicator.BorderSizePixel        = 0
		indicator.BackgroundTransparency = (name == "Chat") and 0 or 1
		indicator.Parent                 = tabHolder
		corner(indicator, 2)

		local tabBtn = button(tabHolder, name, 11)
		tabBtn.TextColor3 = (name == "Chat") and THEME.TextPrimary or THEME.TextSecondary
		tabBtn.Font       = (name == "Chat") and Enum.Font.GothamBold or Enum.Font.Gotham

		local sf = Instance.new("ScrollingFrame")
		sf.Name                 = name
		sf.Size                 = UDim2.new(1, 0, 1, 0)
		sf.BackgroundTransparency = 1
		sf.BorderSizePixel      = 0
		sf.ScrollBarThickness   = 2
		sf.ScrollBarImageColor3 = THEME.Border
		sf.CanvasSize           = UDim2.new(0, 0, 0, 0)
		sf.AutomaticCanvasSize  = Enum.AutomaticSize.Y
		sf.Visible              = (name == "Chat")
		sf.Parent               = contentArea

		local ll = Instance.new("UIListLayout")
		ll.SortOrder = Enum.SortOrder.LayoutOrder
		ll.Padding   = UDim.new(0, 4)
		ll.Parent    = sf
		pad(sf, 8, 8, 8, 8)

		self._tabs[name]      = { btn = tabBtn, indicator = indicator }
		self._tabFrames[name] = sf

		tabBtn.MouseButton1Click:Connect(function()
			self:_switchTab(name)
		end)
	end

	-- ── Input Bar (42px) ─────────────────────────────────────
	local inputBar = Instance.new("Frame")
	inputBar.Name             = "InputBar"
	inputBar.Size             = UDim2.new(1, -14, 0, 34)
	inputBar.Position         = UDim2.new(0, 7, 1, -40)
	inputBar.BackgroundColor3 = THEME.SurfaceLight
	inputBar.BorderSizePixel  = 0
	inputBar.Parent           = win
	corner(inputBar, 8)
	stroke(inputBar, THEME.Border, 1)

	local inputBox = Instance.new("TextBox")
	inputBox.Size                 = UDim2.new(1, -46, 1, 0)
	inputBox.BackgroundTransparency = 1
	inputBox.Font                 = Enum.Font.Gotham
	inputBox.TextSize             = 11
	inputBox.TextColor3           = THEME.TextPrimary
	inputBox.PlaceholderColor3    = THEME.TextMuted
	inputBox.PlaceholderText      = "Message Autonomous..."
	inputBox.TextXAlignment       = Enum.TextXAlignment.Left
	inputBox.ClearTextOnFocus     = false
	inputBox.Text                 = ""
	inputBox.Parent               = inputBar
	pad(inputBox, 0, 0, 0, 10)
	self._inputBox = inputBox

	local sendHolder = Instance.new("Frame")
	sendHolder.Size             = UDim2.new(0, 28, 0, 24)
	sendHolder.Position         = UDim2.new(1, -34, 0.5, -12)
	sendHolder.BackgroundColor3 = THEME.Accent
	sendHolder.BorderSizePixel  = 0
	sendHolder.Parent           = inputBar
	corner(sendHolder, 6)

	local sendBtn = button(sendHolder, "->", 12)
	sendBtn.Font        = Enum.Font.GothamBold
	sendBtn.TextColor3  = THEME.TextPrimary
	self._sendBtn = sendBtn

	-- ── Wire events ──────────────────────────────────────────
	closeBtn.MouseButton1Click:Connect(function() self:close() end)
	reopenBtn.MouseButton1Click:Connect(function() self:open()  end)

	sendBtn.MouseButton1Click:Connect(function() self:_sendMessage() end)
	inputBox.FocusLost:Connect(function(enter)
		if enter then self:_sendMessage() end
	end)

	-- send button hover
	sendBtn.MouseEnter:Connect(function()
		tw(sendHolder, T_FAST, { BackgroundColor3 = THEME.AccentHover })
	end)
	sendBtn.MouseLeave:Connect(function()
		tw(sendHolder, T_FAST, { BackgroundColor3 = THEME.Accent })
	end)

	self:log("System", "Autonomous UI v" .. self._version .. " ready.", "system")

	return self
end

-- ─── Tab Switching ───────────────────────────────────────────
function AutonomousUI:_switchTab(name)
	if self._activeTab == name then return end
	self._activeTab = name

	for tName, data in pairs(self._tabs) do
		local active = (tName == name)
		tw(data.indicator, T_MED,  { BackgroundTransparency = active and 0 or 1 })
		tw(data.btn,       T_FAST, { TextColor3 = active and THEME.TextPrimary or THEME.TextSecondary })
		data.btn.Font = active and Enum.Font.GothamBold or Enum.Font.Gotham
		self._tabFrames[tName].Visible = active
	end
end

-- ─── Bubble Builder ──────────────────────────────────────────
function AutonomousUI:_buildBubble(parent, role, text, order)
	local isUser = (role == "You")

	local row = Instance.new("Frame")
	row.Size                  = UDim2.new(1, 0, 0, 0)
	row.AutomaticSize         = Enum.AutomaticSize.Y
	row.BackgroundTransparency = 1
	row.LayoutOrder           = order
	row.Parent                = parent

	local bubble = Instance.new("Frame")
	bubble.AutomaticSize    = Enum.AutomaticSize.Y
	bubble.Size             = UDim2.new(0.84, 0, 0, 0)
	bubble.Position         = isUser and UDim2.new(0.16, 0, 0, 0) or UDim2.new(0, 0, 0, 0)
	bubble.BackgroundColor3 = isUser and THEME.Accent or THEME.SurfaceLight
	bubble.BorderSizePixel  = 0
	bubble.Parent           = row
	corner(bubble, 8)
	pad(bubble, 6, 8, 6, 8)

	if not isUser then
		stroke(bubble, THEME.Border, 1, 0.4)
		local nt = label(bubble, "Autonomous", 9, THEME.Accent, Enum.TextXAlignment.Left)
		nt.Font        = Enum.Font.GothamBold
		nt.Size        = UDim2.new(1, 0, 0, 13)
		nt.LayoutOrder = 0
	end

	local ml = Instance.new("TextLabel")
	ml.Text              = text
	ml.TextSize          = 11
	ml.TextColor3        = isUser and Color3.new(1,1,1) or THEME.TextPrimary
	ml.Font              = Enum.Font.Gotham
	ml.TextWrapped       = true
	ml.TextXAlignment    = Enum.TextXAlignment.Left
	ml.BackgroundTransparency = 1
	ml.AutomaticSize    = Enum.AutomaticSize.Y
	ml.Size             = UDim2.new(1, 0, 0, 0)
	ml.LayoutOrder      = 1
	ml.Parent           = bubble

	local bl = Instance.new("UIListLayout")
	bl.SortOrder = Enum.SortOrder.LayoutOrder
	bl.Padding   = UDim.new(0, 3)
	bl.Parent    = bubble

	-- fade in
	bubble.BackgroundTransparency = 1
	ml.TextTransparency           = 1
	tw(bubble, T_MED, { BackgroundTransparency = 0 })
	tw(ml,     T_MED, { TextTransparency = 0 })

	return row
end

-- ─── Send Message ────────────────────────────────────────────
function AutonomousUI:_sendMessage()
	local text = self._inputBox.Text
	if not text or text:gsub("%s","") == "" then return end
	self._inputBox.Text = ""

	local order = #self._messages + 1
	table.insert(self._messages, { role = "You", text = text, order = order })

	local cf = self._tabFrames["Chat"]
	self:_buildBubble(cf, "You", text, order)
	self:log("Chat", "You: " .. text, "info")

	if self.onMessage then
		local ok, err = pcall(self.onMessage, self, text)
		if not ok then self:log("Error", tostring(err), "error") end
	else
		task.delay(0.5, function()
			self:reply('Received: "' .. text .. '"')
		end)
	end
end

-- ─── Reply ───────────────────────────────────────────────────
function AutonomousUI:reply(text)
	local cf    = self._tabFrames["Chat"]
	local order = #self._messages + 1
	table.insert(self._messages, { role = "Autonomous", text = text, order = order })
	self:_buildBubble(cf, "Autonomous", text, order)
	self:log("Chat", "Autonomous: " .. text, "info")
	task.defer(function()
		cf.CanvasPosition = Vector2.new(0, cf.AbsoluteCanvasSize.Y)
	end)
end

-- ─── Logs ────────────────────────────────────────────────────
local LOG_C = {
	info    = THEME.Info,
	success = THEME.Success,
	warning = THEME.Warning,
	error   = THEME.Error,
	system  = THEME.Accent,
}

function AutonomousUI:log(tag, message, level)
	level = level or "info"
	local col  = LOG_C[level] or THEME.TextSecondary
	local lf   = self._tabFrames["Logs"]
	local order = #self._logs + 1
	table.insert(self._logs, { tag = tag, message = message, level = level, order = order })

	local row = Instance.new("Frame")
	row.Size             = UDim2.new(1, 0, 0, 0)
	row.AutomaticSize    = Enum.AutomaticSize.Y
	row.BackgroundColor3 = THEME.Surface
	row.BorderSizePixel  = 0
	row.LayoutOrder      = order
	row.Parent           = lf
	corner(row, 5)
	pad(row, 5, 7, 5, 7)
	stroke(row, THEME.Border, 1, 0.5)

	local rl = Instance.new("UIListLayout")
	rl.SortOrder = Enum.SortOrder.LayoutOrder
	rl.Padding   = UDim.new(0, 2)
	rl.Parent    = row

	-- top row: tag + timestamp side by side
	local topRow = Instance.new("Frame")
	topRow.Size                  = UDim2.new(1, 0, 0, 13)
	topRow.BackgroundTransparency = 1
	topRow.LayoutOrder           = 0
	topRow.Parent                = row

	local tagLbl = label(topRow, "[" .. tag:upper() .. "]", 9, col, Enum.TextXAlignment.Left)
	tagLbl.Font = Enum.Font.GothamBold
	tagLbl.Size = UDim2.new(0.6, 0, 1, 0)

	local tsLbl = label(topRow, os.date("%H:%M:%S"), 9, THEME.TextMuted, Enum.TextXAlignment.Right)
	tsLbl.Size     = UDim2.new(0.4, 0, 1, 0)
	tsLbl.Position = UDim2.new(0.6, 0, 0, 0)

	local msgLbl = Instance.new("TextLabel")
	msgLbl.Text              = message
	msgLbl.TextSize          = 10
	msgLbl.TextColor3        = THEME.TextSecondary
	msgLbl.Font              = Enum.Font.Gotham
	msgLbl.TextWrapped       = true
	msgLbl.TextXAlignment    = Enum.TextXAlignment.Left
	msgLbl.BackgroundTransparency = 1
	msgLbl.AutomaticSize    = Enum.AutomaticSize.Y
	msgLbl.Size             = UDim2.new(1, 0, 0, 0)
	msgLbl.LayoutOrder      = 1
	msgLbl.Parent           = row

	task.defer(function()
		lf.CanvasPosition = Vector2.new(0, lf.AbsoluteCanvasSize.Y)
	end)
end

-- ─── Open / Close ────────────────────────────────────────────
function AutonomousUI:close()
	if not self._isOpen then return end
	self._isOpen = false
	self:log("System", "UI closed.", "system")
	tw(self._window, WIN_TW, { Size = UDim2.new(0, WIN_W, 0, 0) })
	task.delay(0.23, function()
		self._window.Visible    = false
		self._reopenBtn.Visible = true
	end)
end

function AutonomousUI:open()
	if self._isOpen then return end
	self._isOpen            = true
	self._window.Visible    = true
	self._window.Size       = UDim2.new(0, WIN_W, 0, 0)
	self._reopenBtn.Visible = false
	tw(self._window, WIN_TW, { Size = UDim2.new(0, WIN_W, 0, WIN_H) })
	self:log("System", "UI opened.", "system")
end

-- ─── Destroy ─────────────────────────────────────────────────
function AutonomousUI:destroy()
	self:log("System", "Shutting down...", "warning")
	task.delay(0.3, function() self._screenGui:Destroy() end)
end

-- ─── Getters ─────────────────────────────────────────────────
function AutonomousUI:getLogs()    return self._logs     end
function AutonomousUI:getHistory() return self._messages end
function AutonomousUI:isOpen()     return self._isOpen   end

return AutonomousUI

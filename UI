-- ══════════════════════════════════════════
--  INTERNAL HELPERS
-- ══════════════════════════════════════════
local function new(class, props, parent)
	local obj = Instance.new(class)
	for k, v in pairs(props) do obj[k] = v end
	if parent then obj.Parent = parent end
	return obj
end

local function corner(r, p)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, r)
	c.Parent = p
	return c
end

local function stroke(t, col, p)
	local s = Instance.new("UIStroke")
	s.Thickness = t
	s.Color = col
	s.Parent = p
	return s
end

local function padding(l, r, t, b, p)
	local pad = Instance.new("UIPadding")
	pad.PaddingLeft   = UDim.new(0, l or 0)
	pad.PaddingRight  = UDim.new(0, r or 0)
	pad.PaddingTop    = UDim.new(0, t or 0)
	pad.PaddingBottom = UDim.new(0, b or 0)
	pad.Parent = p
	return pad
end

local function listLayout(dir, order, pad, p)
	local l = Instance.new("UIListLayout")
	l.FillDirection = dir or Enum.FillDirection.Vertical
	l.SortOrder     = order or Enum.SortOrder.LayoutOrder
	l.Padding       = UDim.new(0, pad or 0)
	l.Parent        = p
	return l
end

local function tween(obj, t, props)
	TweenService:Create(obj, TweenInfo.new(t, Enum.EasingStyle.Quad), props):Play()
end

local function makeDraggable(handle, window)
	local dragging, dragStart, startPos = false, nil, nil

	handle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
			dragging  = true
			dragStart = input.Position
			startPos  = window.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and (
			input.UserInputType == Enum.UserInputType.MouseMovement or
			input.UserInputType == Enum.UserInputType.Touch
		) then
			local d = input.Position - dragStart
			window.Position = UDim2.new(
				startPos.X.Scale,
				startPos.X.Offset + d.X,
				startPos.Y.Scale,
				startPos.Y.Offset + d.Y
			)
		end
	end)
end


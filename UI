-- ─────────────────────────────────────────────────────────────────────────────
--  LOG ENTRY BUILDER
-- ─────────────────────────────────────────────────────────────────────────────
local function buildLogEntry(parent, data)
    -- data = { text, logType, timestamp }
    local logType  = data.logType or "system"
    local typeColor = THEME[logType] or THEME.system

    local entry = Instance.new("Frame")
    entry.Name             = "LogEntry"
    entry.Size             = UDim2.new(1, -8, 0, 0)   -- height auto via layout
    entry.AutomaticSize    = Enum.AutomaticSize.Y
    entry.BackgroundColor3 = THEME.surfaceAlt
    entry.BackgroundTransparency = 0.5
    entry.BorderSizePixel  = 0
    entry.Parent           = parent

    applyCorner(entry, THEME.cornerRSm)

    -- left accent bar
    local bar = Instance.new("Frame")
    bar.Name             = "AccentBar"
    bar.Size             = UDim2.new(0, 3, 1, 0)
    bar.Position         = UDim2.new(0, 0, 0, 0)
    bar.BackgroundColor3 = typeColor
    bar.BorderSizePixel  = 0
    bar.Parent           = entry
    applyCorner(bar, UDim.new(0, 2))

    -- icon + type tag
    local iconMap = { system = ICONS.info, user = ICONS.user, bot = ICONS.bot, warn = "⚠", err = "✕" }
    local icon    = iconMap[logType] or ICONS.dot

    local header = Instance.new("Frame")
    header.Name                  = "Header"
    header.Size                  = UDim2.new(1, -14, 0, 18)
    header.Position              = UDim2.new(0, 10, 0, 6)
    header.BackgroundTransparency = 1
    header.Parent                = entry

    local tag = createLabel(
        string.format('<font color="#%02x%02x%02x">%s %s</font>',
            math.floor(typeColor.R*255), math.floor(typeColor.G*255), math.floor(typeColor.B*255),
            icon, logType:upper()
        ),
        11, typeColor, header
    )
    tag.Size     = UDim2.new(0.4, 0, 1, 0)
    tag.Font     = Enum.Font.GothamBold

    local ts = createLabel(data.timestamp or "", 10, THEME.textMuted, header)
    ts.Size             = UDim2.new(0.6, 0, 1, 0)
    ts.Position         = UDim2.new(0.4, 0, 0, 0)
    ts.TextXAlignment   = Enum.TextXAlignment.Right
    ts.Font             = Enum.Font.Gotham

    -- message body
    local body = createLabel(data.text or "", 13, THEME.textPrimary, entry)
    body.Size     = UDim2.new(1, -20, 0, 0)
    body.Position = UDim2.new(0, 10, 0, 26)
    body.AutomaticSize = Enum.AutomaticSize.Y
    body.Font     = Enum.Font.Gotham

    -- padding at bottom
    local pad = Instance.new("Frame")
    pad.Size                  = UDim2.new(1, 0, 0, 8)
    pad.Position              = UDim2.new(0, 0, 1, 0)  -- will be pushed down by AutoSize
    pad.BackgroundTransparency = 1
    pad.Parent                = entry

    -- fade-in
    entry.BackgroundTransparency = 1
    for _, child in ipairs(entry:GetDescendants()) do
        if child:IsA("TextLabel") or child:IsA("Frame") then
            if child ~= bar then
                local origT = child.BackgroundTransparency
                child.BackgroundTransparency = 1
                tween(child, {BackgroundTransparency = origT}, THEME.tweenQuick)
            end
        end
    end
    tween(entry, {BackgroundTransparency = 0.5}, THEME.tweenQuick)

    return entry
end


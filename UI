                local valLbl = U.Label(row, tostring(value or "—"), C.SmallSz,
                    valueColor or T.Text, C.FontBold, Enum.TextXAlignment.Right)
                valLbl.Size             = UDim2.new(0.5, 0, 1, 0)
                valLbl.LayoutOrder      = 2

                local rowObj = { Frame = row, Key = keyLbl, Value = valLbl }
                self._rows[label] = rowObj

                function rowObj:Set(newVal, newColor)
                    valLbl.Text = tostring(newVal)
                    if newColor then
                        U.Tween(valLbl, {TextColor3 = newColor}, 0.25)
                    end
                end

                return rowObj
            end

            function panel:AddProgressRow(label, value, maxValue, color)
                self._rowCount += 1

                local row = Instance.new("Frame")
                row.Name                = "ProgressRow_" .. label
                row.Size                = UDim2.new(1, 0, 0, 48)
                row.BackgroundColor3    = T.Surface
                row.BorderSizePixel     = 0
                row.LayoutOrder         = self._rowCount
                row.Parent              = container
                U.Corner(row, C.InnerRadius - 2)
                U.Padding(row, 6, 12, 6, 12)
                U.Stroke(row, T.Border, 1)

                local lbl = U.Label(row, label, C.SmallSz, T.TextMuted, C.Font)
                lbl.Size = UDim2.new(1, 0, 0, 16)
                lbl.Position = UDim2.new(0, 0, 0, 0)

                local track = Instance.new("Frame")
                track.Size              = UDim2.new(1, 0, 0, 6)
                track.Position          = UDim2.new(0, 0, 0, 22)
                track.BackgroundColor3  = T.SurfaceAlt
                track.BorderSizePixel   = 0
                track.Parent            = row
                U.Corner(track, 3)

                local fill = Instance.new("Frame")
                local pct = maxValue > 0 and (value / maxValue) or 0
                fill.Size               = UDim2.new(math.clamp(pct, 0, 1), 0, 1, 0)
                fill.BackgroundColor3   = color or T.Accent
                fill.BorderSizePixel    = 0
                fill.Parent             = track
                U.Corner(fill, 3)

                local pctLbl = U.Label(row, math.floor(pct * 100) .. "%",
                    C.TinySz, T.TextMuted, C.FontMono, Enum.TextXAlignment.Right)
                pctLbl.Size = UDim2.new(1, 0, 0, 14)
                pctLbl.Position = UDim2.new(0, 0, 0, 32)

                local progressObj = { Frame = row, Fill = fill, PctLabel = pctLbl }

                function progressObj:Set(newVal, newMax, newColor)
                    newMax = newMax or maxValue
                    local p = newMax > 0 and (newVal / newMax) or 0
                    p = math.clamp(p, 0, 1)
                    U.Tween(fill, {Size = UDim2.new(p, 0, 1, 0)}, 0.3, Enum.EasingStyle.Quad)
                    pctLbl.Text = math.floor(p * 100) .. "%"
                    if newColor then fill.BackgroundColor3 = newColor end
                end

                return progressObj
            end

            return panel
        end  -- end AddStatusPanel

        -- ── components:AddActionBar() ─────────────────────────────────────

        function components:AddActionBar(barOptions)
            barOptions = barOptions or {}
            local barH  = barOptions.Height or 48
            local pos   = barOptions.Position or "bottom"  -- "bottom" | "top"

            local bar = Instance.new("Frame")
            bar.Name                = "ActionBar"
            bar.Size                = UDim2.new(1, 0, 0, barH)
            bar.Position            = pos == "top"
                and UDim2.new(0, 0, 0, 0)
                or  UDim2.new(0, 0, 1, -barH)
            bar.BackgroundColor3    = T.Surface
            bar.BorderSizePixel     = 0
            bar.ZIndex              = 6
            bar.Parent              = tabFrame
            U.Padding(bar, 6, 8, 6, 8)
            U.Stroke(bar, T.Border, 1)

            local barLayout = Instance.new("UIListLayout")
            barLayout.FillDirection = Enum.FillDirection.Horizontal
            barLayout.VerticalAlignment = Enum.VerticalAlignment.Center
            barLayout.HorizontalAlignment = barOptions.Align or Enum.HorizontalAlignment.Left
            barLayout.Padding       = UDim.new(0, 6)
            barLayout.SortOrder     = Enum.SortOrder.LayoutOrder
            barLayout.Parent        = bar

            local barObj = { Frame = bar, _btnCount = 0 }

            function barObj:AddButton(label, color, callback, btnOptions)
                self._btnCount += 1
                btnOptions = btnOptions or {}
                color = color or T.Accent

                local btn = Instance.new("TextButton")
                btn.Name                = "Btn_" .. label
                btn.Size                = UDim2.new(0, 0, 1, 0)
                btn.AutomaticSize       = Enum.AutomaticSize.X
                btn.BackgroundColor3    = color
                btn.Text                = (btnOptions.Icon and btnOptions.Icon .. " " or "") .. label
                btn.TextColor3          = Color3.new(1, 1, 1)
                btn.Font                = C.Font
                btn.TextSize            = C.SmallSz
                btn.BorderSizePixel     = 0
                btn.AutoButtonColor     = false
                btn.ZIndex              = 7
                btn.LayoutOrder         = self._btnCount
                btn.Parent              = bar
                U.Corner(btn, C.InnerRadius - 2)
                U.Padding(btn, 4, 14, 4, 14)

                if btnOptions.Disabled then
                    btn.BackgroundTransparency = 0.5
                    btn.TextTransparency = 0.4
                    btn.Active = false
                end

                btn.MouseEnter:Connect(function()
                    if btn.Active ~= false then
                        U.Tween(btn, {BackgroundTransparency = 0.2}, 0.15)
                    end
                end)
                btn.MouseLeave:Connect(function()
                    U.Tween(btn, {BackgroundTransparency = btnOptions.Disabled and 0.5 or 0}, 0.15)
                end)

                btn.MouseButton1Click:Connect(function()
                    if callback and btn.Active ~= false then
                        -- Brief press flash
                        U.Tween(btn, {BackgroundTransparency = 0.4}, 0.08)
                        task.delay(0.08, function()
                            U.Tween(btn, {BackgroundTransparency = 0}, 0.12)
                        end)
                        task.spawn(callback)
                    end
                end)
                btn.TouchTap:Connect(function()
                    if callback and btn.Active ~= false then
                        task.spawn(callback)
                    end
                end)

                local btnObj = { Button = btn }

                function btnObj:SetDisabled(state)
                    btn.Active = not state
                    U.Tween(btn, {
                        BackgroundTransparency = state and 0.5 or 0,
                        TextTransparency = state and 0.4 or 0,
                    }, 0.2)
                end

                function btnObj:SetLabel(newLabel)
                    btn.Text = (btnOptions.Icon and btnOptions.Icon .. " " or "") .. newLabel
                end

                return btnObj
            end

            -- Spacer (pushes following buttons to the right)
            function barObj:AddSpacer()
                self._btnCount += 1
                local spacer = Instance.new("Frame")
                spacer.Size             = UDim2.new(1, 0, 1, 0)
                spacer.BackgroundTransparency = 1
                spacer.LayoutOrder      = self._btnCount
                spacer.FlexItem         = Instance.new("UIFlexItem")
                spacer.FlexItem.FlexMode = Enum.UIFlexMode.Grow
                spacer.Parent           = bar
                return spacer
            end

            return barObj
        end  -- end AddActionBar

        -- ── components:AddCustom() ────────────────────────────────────────
        -- Gives back a raw Frame for full customisation

        function components:AddCustom(sizeY)
            local frame = Instance.new("Frame")
            frame.Name              = "CustomFrame"
            frame.Size              = sizeY
                and UDim2.new(1, 0, 0, sizeY)
                or  UDim2.new(1, 0, 1, 0)
            frame.BackgroundTransparency = 1
            frame.Parent            = tabFrame
            return frame
        end

        return tab, components
    end  -- end AddTab

    -- ── Window API ────────────────────────────────────────────────────────────

    function window:SetTitle(text)
        self.TitleLabel.Text = text
    end

    function window:SetStatus(text, color)
        self.StatusLabel.Text = "● " .. text
        U.Tween(self.StatusLabel, {TextColor3 = color or T.TextMuted}, 0.3)
    end

    function window:SelectTab(nameOrIndex)
        for _, t in ipairs(self._tabs) do
            if t.Name == nameOrIndex or t.Index == nameOrIndex then
                t.Button.MouseButton1Click:Fire()
                return
            end
        end
    end

    function window:SetTheme(newTheme)
        for k, v in pairs(newTheme) do
            AutonomousUI.Theme[k] = v
        end
    end

    function window:Open()
        doOpen()
    end

    function window:Close()
        doClose()
    end

    function window:Destroy()
        self.ScreenGui:Destroy()
    end

    function window:IsOpen()
        return self._isOpen
    end

    return window
end  -- end CreateWindow


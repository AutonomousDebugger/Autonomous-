-- ─── Internal Utilities ───────────────────────────────────────────────────────

local U = {}  -- namespace for private helpers

function U.Tween(inst, props, dur, style, dir)
    local info = TweenInfo.new(
        dur   or AutonomousUI.Config.AnimSpeed,
        style or Enum.EasingStyle.Quart,
        dir   or Enum.EasingDirection.Out
    )
    local t = TweenService:Create(inst, info, props)
    t:Play()
    return t
end

function U.Corner(parent, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or AutonomousUI.Config.CornerRadius)
    c.Parent = parent
    return c
end

function U.Stroke(parent, color, thickness, mode)
    local s = Instance.new("UIStroke")
    s.Color           = color     or AutonomousUI.Theme.Border
    s.Thickness       = thickness or 1
    s.ApplyStrokeMode = mode      or Enum.ApplyStrokeMode.Border
    s.Parent          = parent
    return s
end

function U.Padding(parent, top, right, bottom, left)
    local p = Instance.new("UIPadding")
    p.PaddingTop    = UDim.new(0, top    or 8)
    p.PaddingRight  = UDim.new(0, right  or top or 8)
    p.PaddingBottom = UDim.new(0, bottom or top or 8)
    p.PaddingLeft   = UDim.new(0, left   or right or top or 8)
    p.Parent = parent
    return p
end

function U.ListLayout(parent, pad, dir, hAlign, vAlign)
    local l = Instance.new("UIListLayout")
    l.Padding            = UDim.new(0, pad or 6)
    l.FillDirection      = dir    or Enum.FillDirection.Vertical
    l.HorizontalAlignment= hAlign or Enum.HorizontalAlignment.Left
    l.VerticalAlignment  = vAlign or Enum.VerticalAlignment.Top
    l.SortOrder          = Enum.SortOrder.LayoutOrder
    l.Parent             = parent
    return l
end

function U.GridLayout(parent, cellSize, spacing)
    local g = Instance.new("UIGridLayout")
    g.CellSize      = cellSize  or UDim2.new(0.5, -4, 0, 32)
    g.CellPadding   = spacing   or UDim2.new(0, 6, 0, 6)
    g.SortOrder     = Enum.SortOrder.LayoutOrder
    g.Parent        = parent
    return g
end

function U.SizeConstraint(parent, minX, minY, maxX, maxY)
    local c = Instance.new("UISizeConstraint")
    c.MinSize = Vector2.new(minX or 0, minY or 0)
    c.MaxSize = Vector2.new(maxX or math.huge, maxY or math.huge)
    c.Parent  = parent
    return c
end

function U.Label(parent, text, sz, color, font, xAlign)
    local l = Instance.new("TextLabel")
    l.Text               = text   or ""
    l.TextSize           = sz     or AutonomousUI.Config.TextSz
    l.TextColor3         = color  or AutonomousUI.Theme.Text
    l.Font               = font   or AutonomousUI.Config.Font
    l.BackgroundTransparency = 1
    l.TextXAlignment     = xAlign or Enum.TextXAlignment.Left
    l.TextWrapped        = true
    l.RichText           = true
    l.Parent             = parent
    return l
end

function U.IsMobile()
    return UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled
end

function U.ScreenSize()
    return workspace.CurrentCamera.ViewportSize
end

-- Timestamp string
function U.Timestamp()
    local t = os.date("*t")
    return string.format("%02d:%02d:%02d", t.hour, t.min, t.sec)
end

-- ─── Drag System (desktop + touch) ───────────────────────────────────────────

function U.MakeDraggable(frame, handle)
    handle = handle or frame
    local dragging  = false
    local dragStart = nil
    local startPos  = nil
    local slop      = AutonomousUI.Config.TouchSlop

    local function clamp(pos)
        local ss  = U.ScreenSize()
        local sz  = frame.AbsoluteSize
        local inset = GuiService:GetGuiInset()
        local minX  = 0
        local minY  = inset.Y
        local maxX  = ss.X - sz.X
        local maxY  = ss.Y - sz.Y
        return UDim2.new(
            0, math.clamp(pos.X.Offset, minX, maxX),
            0, math.clamp(pos.Y.Offset, minY, maxY)
        )
    end

    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging  = true
            dragStart = input.Position
            startPos  = frame.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if not dragging then return end
        if input.UserInputType ~= Enum.UserInputType.MouseMovement
        and input.UserInputType ~= Enum.UserInputType.Touch then return end

        local delta = input.Position - dragStart
        if delta.Magnitude < slop then return end

        frame.Position = clamp(UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        ))
    end)
end

-- ─── Shadow helper ────────────────────────────────────────────────────────────

-- Roblox shadow via UIStroke glow or image label trick
function U.AddShadow(parent, spread, opacity)
    local shadow = Instance.new("ImageLabel")
    shadow.Name              = "_Shadow"
    shadow.AnchorPoint       = Vector2.new(0.5, 0.5)
    shadow.Size              = UDim2.new(1, spread or 40, 1, spread or 40)
    shadow.Position          = UDim2.new(0.5, 0, 0.5, (spread or 40) * 0.2)
    shadow.BackgroundTransparency = 1
    -- Standard Roblox square-gradient asset used for soft drop shadows
    shadow.Image             = "rbxassetid://1316045217"
    shadow.ImageColor3       = Color3.fromRGB(0, 0, 0)
    shadow.ImageTransparency = opacity or 0.55
    shadow.ScaleType         = Enum.ScaleType.Slice
    shadow.SliceCenter       = Rect.new(10, 10, 118, 118)
    shadow.ZIndex            = (parent.ZIndex or 1) - 1
    shadow.Parent            = parent
    return shadow
end

-- ─── CreateWindow ─────────────────────────────────────────────────────────────

function AutonomousUI:CreateWindow(options)
    options = options or {}

    local T   = self.Theme
    local C   = self.Config
    local W   = options.Width    or C.WindowWidth
    local H   = options.Height   or C.WindowHeight
    local title = options.Title  or "Autonomous"

    -- ── ScreenGui ──
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name            = "AutonomousUI_" .. title
    screenGui.ResetOnSpawn    = false
    screenGui.ZIndexBehavior  = Enum.ZIndexBehavior.Sibling
    screenGui.DisplayOrder    = 999
    screenGui.IgnoreGuiInset  = false
    screenGui.Parent          = PlayerGui

    -- ── Reopen Button (shown when window is closed) ──
    local reopenBtn = Instance.new("TextButton")
    reopenBtn.Name              = "ReopenButton"
    reopenBtn.Size              = UDim2.new(0, C.ReopenSize, 0, C.ReopenSize)
    reopenBtn.Position          = UDim2.new(0, C.ReopenOffset, 0.5, -C.ReopenSize / 2)
    reopenBtn.AnchorPoint       = Vector2.new(0, 0.5)
    reopenBtn.BackgroundColor3  = T.Accent
    reopenBtn.Text              = "✦"
    reopenBtn.TextColor3        = Color3.new(1, 1, 1)
    reopenBtn.TextSize          = 20
    reopenBtn.Font              = C.FontBold
    reopenBtn.BorderSizePixel   = 0
    reopenBtn.Visible           = false
    reopenBtn.ZIndex            = 12
    reopenBtn.AutoButtonColor   = false
    reopenBtn.Parent            = screenGui
    U.Corner(reopenBtn, 12)
    U.AddShadow(reopenBtn, 24, 0.5)

    -- Pulse ring on reopen button
    local pulse = Instance.new("Frame")
    pulse.Name                  = "Pulse"
    pulse.Size                  = UDim2.new(1, 0, 1, 0)
    pulse.Position              = UDim2.new(0, 0, 0, 0)
    pulse.BackgroundColor3      = T.Accent
    pulse.BackgroundTransparency= 0.7
    pulse.BorderSizePixel       = 0
    pulse.ZIndex                = reopenBtn.ZIndex - 1
    pulse.Parent                = reopenBtn
    U.Corner(pulse, 12)

    -- ── Main Frame ──
    local mainFrame = Instance.new("Frame")
    mainFrame.Name              = "MainFrame"
    mainFrame.Size              = UDim2.new(0, W, 0, H)
    mainFrame.Position          = UDim2.new(0.5, -W / 2, 0.5, -H / 2)
    mainFrame.BackgroundColor3  = T.Background
    mainFrame.BorderSizePixel   = 0
    mainFrame.ClipsDescendants  = true
    mainFrame.ZIndex            = 5
    mainFrame.Parent            = screenGui
    U.Corner(mainFrame, C.CornerRadius)
    U.Stroke(mainFrame, T.Border, 1)
    U.SizeConstraint(mainFrame, 280, 360)

    -- Shadow behind window
    U.AddShadow(mainFrame, 50, 0.45)

    -- ── Title Bar ──
    local titleBar = Instance.new("Frame")
    titleBar.Name               = "TitleBar"
    titleBar.Size               = UDim2.new(1, 0, 0, C.TitleBarH)
    titleBar.BackgroundColor3   = T.Surface
    titleBar.BorderSizePixel    = 0
    titleBar.ZIndex             = 6
    titleBar.Parent             = mainFrame

    -- Bottom accent line on title bar
    local accentLine = Instance.new("Frame")
    accentLine.Size             = UDim2.new(0, 32, 0, 2)
    accentLine.Position         = UDim2.new(0, 14, 1, -2)
    accentLine.BackgroundColor3 = T.Accent
    accentLine.BorderSizePixel  = 0
    accentLine.ZIndex           = 7
    accentLine.Parent           = titleBar
    U.Corner(accentLine, 2)

    -- Separator line full width
    local sep = Instance.new("Frame")
    sep.Size                    = UDim2.new(1, 0, 0, 1)
    sep.Position                = UDim2.new(0, 0, 1, -1)
    sep.BackgroundColor3        = T.Border
    sep.BorderSizePixel         = 0
    sep.ZIndex                  = 7
    sep.Parent                  = titleBar

    -- Icon dot (AI status dot)
    local iconDot = Instance.new("Frame")
    iconDot.Size                = UDim2.new(0, 8, 0, 8)
    iconDot.Position            = UDim2.new(0, 14, 0.5, -4)
    iconDot.BackgroundColor3    = T.Accent
    iconDot.BorderSizePixel     = 0
    iconDot.ZIndex              = 8
    iconDot.Parent              = titleBar
    U.Corner(iconDot, 4)

    -- Title label
    local titleLabel = U.Label(titleBar, title, C.TitleSz, T.Text, C.FontBold)
    titleLabel.Size             = UDim2.new(1, -90, 0, 20)
    titleLabel.Position         = UDim2.new(0, 28, 0, 8)
    titleLabel.ZIndex           = 8

    -- Status sub-label
    local statusLabel = U.Label(titleBar, "● Idle", C.TinySz, T.TextMuted, C.Font)
    statusLabel.Size            = UDim2.new(1, -90, 0, 14)
    statusLabel.Position        = UDim2.new(0, 28, 0, 28)
    statusLabel.ZIndex          = 8

    -- Close Button
    local closeBtn = Instance.new("TextButton")
    closeBtn.Name               = "CloseButton"
    closeBtn.Size               = UDim2.new(0, 28, 0, 28)
    closeBtn.Position           = UDim2.new(1, -38, 0.5, -14)
    closeBtn.BackgroundColor3   = Color3.fromRGB(196, 58, 58)
    closeBtn.Text               = "✕"
    closeBtn.TextColor3         = Color3.new(1, 1, 1)
    closeBtn.TextSize           = 12
    closeBtn.Font               = C.FontBold
    closeBtn.BorderSizePixel    = 0
    closeBtn.AutoButtonColor    = false
    closeBtn.ZIndex             = 9
    closeBtn.Parent             = titleBar
    U.Corner(closeBtn, 7)

    closeBtn.MouseEnter:Connect(function()
        U.Tween(closeBtn, {BackgroundColor3 = Color3.fromRGB(230, 75, 75)}, 0.15)
    end)
    closeBtn.MouseLeave:Connect(function()
        U.Tween(closeBtn, {BackgroundColor3 = Color3.fromRGB(196, 58, 58)}, 0.15)
    end)

    -- ── Tab Bar ──
    local tabBar = Instance.new("Frame")
    tabBar.Name                 = "TabBar"
    tabBar.Size                 = UDim2.new(1, 0, 0, C.TabBarH)
    tabBar.Position             = UDim2.new(0, 0, 0, C.TitleBarH)
    tabBar.BackgroundColor3     = T.Surface
    tabBar.BorderSizePixel      = 0
    tabBar.ZIndex               = 6
    tabBar.Parent               = mainFrame

    local tabSep = Instance.new("Frame")
    tabSep.Size                 = UDim2.new(1, 0, 0, 1)
    tabSep.Position             = UDim2.new(0, 0, 1, -1)
    tabSep.BackgroundColor3     = T.Border
    tabSep.BorderSizePixel      = 0
    tabSep.ZIndex               = 7
    tabSep.Parent               = tabBar

    local tabLayout = U.ListLayout(tabBar, 0, Enum.FillDirection.Horizontal,
        Enum.HorizontalAlignment.Left, Enum.VerticalAlignment.Center)

    U.Padding(tabBar, 0, 6, 0, 6)

    -- ── Content Area ──
    local contentY = C.TitleBarH + C.TabBarH
    local contentArea = Instance.new("Frame")
    contentArea.Name            = "ContentArea"
    contentArea.Size            = UDim2.new(1, 0, 1, -contentY)
    contentArea.Position        = UDim2.new(0, 0, 0, contentY)
    contentArea.BackgroundTransparency = 1
    contentArea.ClipsDescendants= true
    contentArea.ZIndex          = 5
    contentArea.Parent          = mainFrame

    -- Drag via title bar
    U.MakeDraggable(mainFrame, titleBar)

    -- ── Window Object ──
    local window = {
        ScreenGui    = screenGui,
        MainFrame    = mainFrame,
        TitleBar     = titleBar,
        TitleLabel   = titleLabel,
        StatusLabel  = statusLabel,
        TabBar       = tabBar,
        ContentArea  = contentArea,
        ReopenButton = reopenBtn,
        CloseButton  = closeBtn,
        _tabs        = {},
        _activeTab   = nil,
        _isOpen      = true,
        _W           = W,
        _H           = H,
        _connections = {},
    }

    -- ── Animate: Close ──
    local function doClose()
        if not window._isOpen then return end
        window._isOpen = false

        local origPos = mainFrame.Position
        U.Tween(mainFrame, {
            Size     = UDim2.new(0, W, 0, 0),
            Position = UDim2.new(origPos.X.Scale, origPos.X.Offset, origPos.Y.Scale, origPos.Y.Offset + H * 0.04),
        }, C.AnimSpeed, C.CloseStyle, Enum.EasingDirection.In)
        U.Tween(mainFrame, {BackgroundTransparency = 1}, C.AnimSpeed * 0.9)

        -- Also fade children
        for _, d in ipairs(mainFrame:GetDescendants()) do
            if d:IsA("TextLabel") or d:IsA("TextButton") or d:IsA("TextBox") then
                U.Tween(d, {TextTransparency = 1}, C.AnimSpeed * 0.7)
            end
            if d:IsA("Frame") or d:IsA("ScrollingFrame") then
                if d.BackgroundTransparency < 1 then
                    U.Tween(d, {BackgroundTransparency = 1}, C.AnimSpeed * 0.7)
                end
            end
        end

        task.delay(C.AnimSpeed + 0.05, function()
            mainFrame.Visible = false

            -- Restore transparencies for next open
            for _, d in ipairs(mainFrame:GetDescendants()) do
                if d:IsA("TextLabel") or d:IsA("TextButton") or d:IsA("TextBox") then
                    d.TextTransparency = 0
                end
                if d:IsA("Frame") or d:IsA("ScrollingFrame") then
                    -- we'll let CreateWindow set them properly on rebuild
                end
            end

            -- Show reopen with bounce-in
            reopenBtn.Visible           = true
            reopenBtn.BackgroundTransparency = 1
            reopenBtn.Size              = UDim2.new(0, C.ReopenSize * 0.6, 0, C.ReopenSize * 0.6)
            reopenBtn.Position          = UDim2.new(
                0, C.ReopenOffset + (C.ReopenSize - C.ReopenSize * 0.6) / 2,
                0.5, -C.ReopenSize * 0.3
            )
            U.Tween(reopenBtn, {
                BackgroundTransparency = 0,
                Size     = UDim2.new(0, C.ReopenSize, 0, C.ReopenSize),
                Position = UDim2.new(0, C.ReopenOffset, 0.5, -C.ReopenSize / 2),
            }, 0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

            -- Animate pulse ring
            local function pulseTick()
                if not reopenBtn.Visible then return end
                U.Tween(pulse, {
                    Size = UDim2.new(1.5, 0, 1.5, 0),
                    Position = UDim2.new(-0.25, 0, -0.25, 0),
                    BackgroundTransparency = 1,
                }, 0.8, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
                task.delay(0.85, function()
                    if reopenBtn.Visible then
                        pulse.Size                  = UDim2.new(1, 0, 1, 0)
                        pulse.Position              = UDim2.new(0, 0, 0, 0)
                        pulse.BackgroundTransparency= 0.7
                    end
                end)
            end

            task.spawn(function()
                while reopenBtn.Visible do
                    pulseTick()
                    task.wait(1.6)
                end
            end)
        end)
    end

    -- ── Animate: Open ──
    local function doOpen()
        if window._isOpen then return end
        window._isOpen = true

        -- Hide reopen
        U.Tween(reopenBtn, {
            BackgroundTransparency = 1,
            Size = UDim2.new(0, C.ReopenSize * 0.6, 0, C.ReopenSize * 0.6),
        }, 0.18)

        task.delay(0.12, function()
            reopenBtn.Visible = false

            -- Reset main frame state
            mainFrame.Visible           = true
            mainFrame.BackgroundTransparency = 0
            mainFrame.Size              = UDim2.new(0, W, 0, H * 0.7)

            local target = UDim2.new(0, W, 0, H)
            U.Tween(mainFrame, {Size = target}, C.AnimSpeed + 0.05, C.OpenStyle, Enum.EasingDirection.Out)
        end)
    end

    -- Wire up buttons
    closeBtn.MouseButton1Click:Connect(doClose)
    closeBtn.TouchTap:Connect(doClose)
    reopenBtn.MouseButton1Click:Connect(doOpen)
    reopenBtn.TouchTap:Connect(doOpen)

    -- Hover reopen
    reopenBtn.MouseEnter:Connect(function()
        U.Tween(reopenBtn, {BackgroundColor3 = T.AccentDim}, 0.15)
    end)
    reopenBtn.MouseLeave:Connect(function()
        U.Tween(reopenBtn, {BackgroundColor3 = T.Accent}, 0.15)
    end)

    -- ── AddTab ────────────────────────────────────────────────────────────────

    function window:AddTab(tabName, icon)
        local tabIdx = #self._tabs + 1

        -- Tab button
        local tabBtn = Instance.new("TextButton")
        tabBtn.Name             = "Tab_" .. tabName
        tabBtn.Size             = UDim2.new(0, 0, 1, 0)
        tabBtn.AutomaticSize    = Enum.AutomaticSize.X
        tabBtn.BackgroundTransparency = 1
        tabBtn.Text             = (icon and icon .. " " or "") .. tabName
        tabBtn.TextColor3       = T.TextMuted
        tabBtn.Font             = C.Font
        tabBtn.TextSize         = C.SmallSz
        tabBtn.BorderSizePixel  = 0
        tabBtn.AutoButtonColor  = false
        tabBtn.ZIndex           = 7
        tabBtn.LayoutOrder      = tabIdx
        tabBtn.Parent           = tabBar
        U.Padding(tabBtn, 0, 12, 0, 12)

        -- Active underline
        local underline = Instance.new("Frame")
        underline.Size              = UDim2.new(1, -16, 0, 2)
        underline.Position          = UDim2.new(0, 8, 1, -2)
        underline.BackgroundColor3  = T.Accent
        underline.BorderSizePixel   = 0
        underline.BackgroundTransparency = 1
        underline.ZIndex            = 8
        underline.Parent            = tabBtn
        U.Corner(underline, 1)

        -- Tab content frame
        local tabFrame = Instance.new("Frame")
        tabFrame.Name               = "Content_" .. tabName
        tabFrame.Size               = UDim2.new(1, 0, 1, 0)
        tabFrame.BackgroundTransparency = 1
        tabFrame.Visible            = false
        tabFrame.ClipsDescendants   = true
        tabFrame.ZIndex             = 5
        tabFrame.Parent             = contentArea

        -- Tab record
        local tab = {
            Name      = tabName,
            Button    = tabBtn,
            Frame     = tabFrame,
            Underline = underline,
            Index     = tabIdx,
        }
        table.insert(self._tabs, tab)

        -- Select logic
        local function selectTab()
            for _, t in ipairs(self._tabs) do
                t.Frame.Visible = false
                U.Tween(t.Underline, {BackgroundTransparency = 1}, 0.18)
                U.Tween(t.Button,   {TextColor3 = T.TextMuted}, 0.18)
            end
            tabFrame.Visible = true
            U.Tween(underline, {BackgroundTransparency = 0}, 0.2)
            U.Tween(tabBtn,   {TextColor3 = T.Text}, 0.18)
            self._activeTab = tab
        end

        tabBtn.MouseButton1Click:Connect(selectTab)
        tabBtn.TouchTap:Connect(selectTab)

        -- Hover
        tabBtn.MouseEnter:Connect(function()
            if self._activeTab ~= tab then
                U.Tween(tabBtn, {TextColor3 = T.Text}, 0.15)
            end
        end)
        tabBtn.MouseLeave:Connect(function()
            if self._activeTab ~= tab then
                U.Tween(tabBtn, {TextColor3 = T.TextMuted}, 0.15)
            end
        end)

        -- Auto-select first tab
        if tabIdx == 1 then selectTab() end

        -- ── Component Builder ──────────────────────────────────────────────

        local components = { _tab = tab, _tabFrame = tabFrame }

        -- ── components:AddChat() ──────────────────────────────────────────

        function components:AddChat(chatOptions)
            chatOptions = chatOptions or {}
            local inputH = U.IsMobile() and C.MobileInputH or 52

            local container = Instance.new("Frame")
            container.Name              = "ChatContainer"
            container.Size              = UDim2.new(1, 0, 1, 0)
            container.BackgroundTransparency = 1
            container.Parent            = tabFrame

            -- ── Messages scroll ──
            local scroll = Instance.new("ScrollingFrame")
            scroll.Name                 = "Messages"
            scroll.Size                 = UDim2.new(1, 0, 1, -(inputH + 1))
            scroll.BackgroundTransparency = 1
            scroll.BorderSizePixel      = 0
            scroll.ScrollBarThickness   = 3
            scroll.ScrollBarImageColor3 = T.ScrollBar
            scroll.CanvasSize           = UDim2.new(0, 0, 0, 0)
            scroll.AutomaticCanvasSize  = Enum.AutomaticSize.Y
            scroll.ScrollingDirection   = Enum.ScrollingDirection.Y
            scroll.ClipsDescendants     = true
            scroll.ElasticBehavior      = Enum.ElasticBehavior.WhenScrollable
            scroll.Parent               = container
            U.Padding(scroll, 10, 10, 10, 10)
            U.ListLayout(scroll, 10)

            -- ── Input area ──
            local inputArea = Instance.new("Frame")
            inputArea.Name              = "InputArea"
            inputArea.Size              = UDim2.new(1, 0, 0, inputH)
            inputArea.Position          = UDim2.new(0, 0, 1, -inputH)
            inputArea.BackgroundColor3  = T.Surface
            inputArea.BorderSizePixel   = 0
            inputArea.ZIndex            = 6
            inputArea.Parent            = container
            U.Stroke(inputArea, T.Border, 1)
            U.Padding(inputArea, 8, 8, 8, 8)

            local inputLayout = Instance.new("UIListLayout")
            inputLayout.FillDirection       = Enum.FillDirection.Horizontal
            inputLayout.VerticalAlignment   = Enum.VerticalAlignment.Center
            inputLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left
            inputLayout.Padding             = UDim.new(0, 6)
            inputLayout.Parent              = inputArea

            -- TextBox
            local inputBox = Instance.new("TextBox")
            inputBox.Name               = "InputBox"
            inputBox.Size               = UDim2.new(1, -44, 1, 0)
            inputBox.BackgroundColor3   = T.SurfaceAlt
            inputBox.Text               = ""
            inputBox.PlaceholderText    = chatOptions.Placeholder or "Message Autonomous..."
            inputBox.PlaceholderColor3  = T.TextMuted
            inputBox.TextColor3         = T.Text
            inputBox.Font               = C.Font
            inputBox.TextSize           = C.TextSz
            inputBox.ClearTextOnFocus   = false
            inputBox.MultiLine          = false
            inputBox.TextXAlignment     = Enum.TextXAlignment.Left
            inputBox.BorderSizePixel    = 0
            inputBox.ZIndex             = 7
            inputBox.LayoutOrder        = 1
            inputBox.Parent             = inputArea
            U.Corner(inputBox, C.InnerRadius)
            U.Padding(inputBox, 0, 12, 0, 12)

            local inputStroke = U.Stroke(inputBox, T.Border, 1)
            inputBox.Focused:Connect(function()
                U.Tween(inputStroke, {Color = T.Accent}, 0.2)
                U.Tween(inputBox, {BackgroundColor3 = T.SurfaceHover}, 0.15)
            end)
            inputBox.FocusLost:Connect(function()
                U.Tween(inputStroke, {Color = T.Border}, 0.2)
                U.Tween(inputBox, {BackgroundColor3 = T.SurfaceAlt}, 0.15)
            end)

            -- Send button
            local sendBtn = Instance.new("TextButton")
            sendBtn.Name                = "SendButton"
            sendBtn.Size                = UDim2.new(0, 38, 0, 38)
            sendBtn.BackgroundColor3    = T.Accent
            sendBtn.Text                = "↑"
            sendBtn.TextColor3          = Color3.new(1, 1, 1)
            sendBtn.TextSize            = 17
            sendBtn.Font                = C.FontBold
            sendBtn.BorderSizePixel     = 0
            sendBtn.AutoButtonColor     = false
            sendBtn.ZIndex              = 7
            sendBtn.LayoutOrder         = 2
            sendBtn.Parent              = inputArea
            U.Corner(sendBtn, C.InnerRadius)

            sendBtn.MouseEnter:Connect(function()
                U.Tween(sendBtn, {BackgroundColor3 = T.AccentDim}, 0.15)
            end)
            sendBtn.MouseLeave:Connect(function()
                U.Tween(sendBtn, {BackgroundColor3 = T.Accent}, 0.15)
            end)

            -- ── Chat object ──
            local chat = {
                Container     = container,
                Scroll        = scroll,
                InputBox      = inputBox,
                SendButton    = sendBtn,
                _msgCount     = 0,
                _typingBubble = nil,
                _typingTask   = nil,
            }

            -- scroll to bottom helper
            local function scrollToBottom()
                task.defer(function()
                    task.wait(0.05)
                    scroll.CanvasPosition = Vector2.new(0, scroll.AbsoluteCanvasSize.Y)
                end)
            end

            -- ── AddMessage ────────────────────────────────────────────────
            --[[
                msgType: "user" | "ai" | "system" | "error" | "info"
                options: { timestamp = bool }
            --]]
            function chat:AddMessage(text, sender, msgType, msgOptions)
                msgOptions = msgOptions or {}
                self._msgCount += 1
                msgType = msgType or "ai"

                local isUser   = msgType == "user"
                local isSystem = msgType == "system"
                local isError  = msgType == "error"
                local isInfo   = msgType == "info"

                local bubbleColor = T.Surface
                local textColor   = T.Text
                local borderColor = T.Border
                local senderColor = T.TextMuted

                if isUser then
                    bubbleColor = T.Accent
                    textColor   = Color3.new(1, 1, 1)
                    borderColor = T.AccentDim
                    senderColor = T.Accent
                elseif isSystem then
                    bubbleColor = T.SurfaceAlt
                    textColor   = T.TextMuted
                    borderColor = T.Border
                elseif isError then
                    bubbleColor = Color3.fromRGB(50, 18, 18)
                    textColor   = T.Error
                    borderColor = T.Error
                    senderColor = T.Error
                elseif isInfo then
                    bubbleColor = T.SurfaceAlt
                    textColor   = T.Info
                    borderColor = T.Info
                    senderColor = T.Info
                end

                -- Wrapper
                local wrapper = Instance.new("Frame")
                wrapper.Name                = "Msg_" .. self._msgCount
                wrapper.Size                = UDim2.new(1, 0, 0, 0)
                wrapper.AutomaticSize       = Enum.AutomaticSize.Y
                wrapper.BackgroundTransparency = 1
                wrapper.LayoutOrder         = self._msgCount
                wrapper.Parent              = scroll

                -- Sender row
                if sender and not isSystem then
                    local senderRow = Instance.new("Frame")
                    senderRow.Size              = UDim2.new(1, 0, 0, 16)
                    senderRow.BackgroundTransparency = 1
                    senderRow.Parent            = wrapper

                    local sLabel = U.Label(senderRow, sender, C.TinySz + 1, senderColor, C.FontBold,
                        isUser and Enum.TextXAlignment.Right or Enum.TextXAlignment.Left)
                    sLabel.Size = UDim2.new(1, 0, 1, 0)
                end

                -- Bubble
                local bubble = Instance.new("Frame")
                bubble.Size                 = isSystem and UDim2.new(1, 0, 0, 0) or UDim2.new(0.82, 0, 0, 0)
                bubble.AutomaticSize        = Enum.AutomaticSize.Y
                bubble.BackgroundColor3     = bubbleColor
                bubble.BorderSizePixel      = 0
                bubble.BackgroundTransparency= 0
                bubble.Position             = isUser
                    and UDim2.new(1, 0, 0, sender and 18 or 0)
                    or  UDim2.new(0, 0, 0, sender and 18 or 0)
                bubble.AnchorPoint          = isUser and Vector2.new(1, 0) or Vector2.new(0, 0)
                bubble.Parent               = wrapper
                U.Corner(bubble, C.InnerRadius)
                U.Stroke(bubble, borderColor, 1)
                U.Padding(bubble, 8, 12, 8, 12)

                local msgLabel = U.Label(bubble, text, C.TextSz, textColor, C.Font)
                msgLabel.Size               = UDim2.new(1, 0, 0, 0)
                msgLabel.AutomaticSize      = Enum.AutomaticSize.Y
                msgLabel.RichText           = true

                -- Optional timestamp
                if msgOptions.timestamp ~= false then
                    local tsLabel = U.Label(bubble, U.Timestamp(), C.TinySz, T.TextDim, C.FontMono,
                        isUser and Enum.TextXAlignment.Right or Enum.TextXAlignment.Left)
                    tsLabel.Size = UDim2.new(1, 0, 0, 12)
                end

                -- Fade-in animation
                bubble.BackgroundTransparency = 1
                msgLabel.TextTransparency = 1

                task.defer(function()
                    U.Tween(bubble, {BackgroundTransparency = 0}, 0.22)
                    U.Tween(msgLabel, {TextTransparency = 0}, 0.22)
                    scrollToBottom()
                end)

                return wrapper, bubble
            end

            -- ── ShowTyping ────────────────────────────────────────────────
            function chat:ShowTyping(senderName)
                self:HideTyping()

                local typingFrame = Instance.new("Frame")
                typingFrame.Name        = "TypingIndicator"
                typingFrame.Size        = UDim2.new(0, 68, 0, 30)
                typingFrame.BackgroundColor3 = T.Surface
                typingFrame.BorderSizePixel  = 0
                typingFrame.LayoutOrder      = 999998
                typingFrame.Parent           = scroll
                U.Corner(typingFrame, C.InnerRadius)
                U.Stroke(typingFrame, T.Border, 1)

                local dotsLabel = U.Label(typingFrame, "• • •", 15, T.TextMuted, C.Font,
                    Enum.TextXAlignment.Center)
                dotsLabel.Size = UDim2.new(1, 0, 1, 0)

                self._typingBubble = typingFrame
                local dotCycle = {"•", "• •", "• • •"}
                local alive = true

                self._typingTask = task.spawn(function()
                    local i = 0
                    while alive and typingFrame and typingFrame.Parent do
                        i = (i % 3) + 1
                        dotsLabel.Text = dotCycle[i]
                        task.wait(0.38)
                    end
                end)

                scrollToBottom()
                return typingFrame
            end

            -- ── HideTyping ────────────────────────────────────────────────
            function chat:HideTyping()
                if self._typingTask then
                    task.cancel(self._typingTask)
                    self._typingTask = nil
                end
                if self._typingBubble and self._typingBubble.Parent then
                    self._typingBubble:Destroy()
                end
                self._typingBubble = nil
            end

            -- ── OnSend ────────────────────────────────────────────────────
            function chat:OnSend(callback)
                local function fire()
                    local text = inputBox.Text
                    if text and #text:gsub("%s+", "") > 0 then
                        inputBox.Text = ""
                        task.spawn(callback, text)
                    end
                end
                sendBtn.MouseButton1Click:Connect(fire)
                sendBtn.TouchTap:Connect(fire)
                inputBox.FocusLost:Connect(function(enter)
                    if enter then fire() end
                end)
            end

            -- ── Clear ─────────────────────────────────────────────────────
            function chat:Clear()
                for _, c in ipairs(scroll:GetChildren()) do
                    if c:IsA("Frame") then c:Destroy() end
                end
                self._msgCount = 0
            end

            -- ── SetPlaceholder ────────────────────────────────────────────
            function chat:SetPlaceholder(text)
                inputBox.PlaceholderText = text
            end

            -- ── SetInputEnabled ───────────────────────────────────────────
            function chat:SetInputEnabled(state)
                inputBox.TextEditable   = state
                sendBtn.Active          = state
                U.Tween(inputBox, {BackgroundTransparency = state and 0 or 0.5}, 0.2)
                U.Tween(sendBtn, {BackgroundTransparency = state and 0 or 0.5}, 0.2)
            end

            return chat
        end  -- end AddChat

        -- ── components:AddLogs() ──────────────────────────────────────────

        function components:AddLogs(logsOptions)
            logsOptions = logsOptions or {}
            local maxLines = logsOptions.MaxLines or 500

            local container = Instance.new("Frame")
            container.Name              = "LogsContainer"
            container.Size              = UDim2.new(1, 0, 1, 0)
            container.BackgroundTransparency = 1
            container.Parent            = tabFrame

            -- Header bar
            local header = Instance.new("Frame")
            header.Name                 = "Header"
            header.Size                 = UDim2.new(1, 0, 0, 36)
            header.BackgroundColor3     = T.Surface
            header.BorderSizePixel      = 0
            header.ZIndex               = 6
            header.Parent               = container
            U.Stroke(header, T.Border, 1)

            local headerLayout = Instance.new("UIListLayout")
            headerLayout.FillDirection  = Enum.FillDirection.Horizontal
            headerLayout.VerticalAlignment = Enum.VerticalAlignment.Center
            headerLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left
            headerLayout.Padding        = UDim.new(0, 8)
            headerLayout.SortOrder      = Enum.SortOrder.LayoutOrder
            headerLayout.Parent         = header
            U.Padding(header, 0, 8, 0, 10)

            local titleLbl = U.Label(header, logsOptions.Title or "System Logs",
                C.SmallSz, T.Text, C.FontBold)
            titleLbl.Size               = UDim2.new(1, -80, 1, 0)
            titleLbl.LayoutOrder        = 1

            -- Filter dropdown (simple cycle button)
            local filterBtn = Instance.new("TextButton")
            filterBtn.Size              = UDim2.new(0, 44, 0, 22)
            filterBtn.BackgroundColor3  = T.SurfaceAlt
            filterBtn.Text              = "ALL"
            filterBtn.TextColor3        = T.TextMuted
            filterBtn.Font              = C.Font
            filterBtn.TextSize          = C.TinySz + 1
            filterBtn.BorderSizePixel   = 0
            filterBtn.AutoButtonColor   = false
            filterBtn.ZIndex            = 7
            filterBtn.LayoutOrder       = 2
            filterBtn.Parent            = header
            U.Corner(filterBtn, 5)

            -- Clear button
            local clearBtn = Instance.new("TextButton")
            clearBtn.Size               = UDim2.new(0, 44, 0, 22)
            clearBtn.BackgroundColor3   = T.SurfaceAlt
            clearBtn.Text               = "CLEAR"
            clearBtn.TextColor3         = T.TextMuted
            clearBtn.Font               = C.Font
            clearBtn.TextSize           = C.TinySz + 1
            clearBtn.BorderSizePixel    = 0
            clearBtn.AutoButtonColor    = false
            clearBtn.ZIndex             = 7
            clearBtn.LayoutOrder        = 3
            clearBtn.Parent             = header
            U.Corner(clearBtn, 5)

            clearBtn.MouseEnter:Connect(function()
                U.Tween(clearBtn, {TextColor3 = T.Error}, 0.15)
            end)
            clearBtn.MouseLeave:Connect(function()
                U.Tween(clearBtn, {TextColor3 = T.TextMuted}, 0.15)
            end)

            -- Scroll frame
            local scroll = Instance.new("ScrollingFrame")
            scroll.Name                 = "LogsScroll"
            scroll.Size                 = UDim2.new(1, 0, 1, -36)
            scroll.Position             = UDim2.new(0, 0, 0, 36)
            scroll.BackgroundTransparency = 1
            scroll.BorderSizePixel      = 0
            scroll.ScrollBarThickness   = 3
            scroll.ScrollBarImageColor3 = T.ScrollBar
            scroll.CanvasSize           = UDim2.new(0, 0, 0, 0)
            scroll.AutomaticCanvasSize  = Enum.AutomaticSize.Y
            scroll.ScrollingDirection   = Enum.ScrollingDirection.Y
            scroll.ElasticBehavior      = Enum.ElasticBehavior.WhenScrollable
            scroll.Parent               = container
            U.Padding(scroll, 5, 8, 5, 8)
            U.ListLayout(scroll, 2)

            -- Level colors & labels
            local LEVELS = {
                info    = { color = T.Info,    icon = "ℹ" },
                warn    = { color = T.Warning, icon = "⚠" },
                error   = { color = T.Error,   icon = "✕" },
                success = { color = T.Success, icon = "✓" },
                debug   = { color = T.TextMuted, icon = "·" },
                system  = { color = T.Accent,  icon = "⬡" },
                verbose = { color = T.TextDim, icon = "·" },
            }

            local logs = {
                Container  = container,
                Scroll     = scroll,
                _count     = 0,
                _entries   = {},
                _filter    = nil,  -- nil = all
            }

            local function scrollToBottom()
                task.defer(function()
                    task.wait(0.04)
                    scroll.CanvasPosition = Vector2.new(0, scroll.AbsoluteCanvasSize.Y)
                end)
            end

            -- ── Log ───────────────────────────────────────────────────────
            function logs:Log(message, level, tag)
                self._count += 1
                level = (level or "info"):lower()
                local meta = LEVELS[level] or LEVELS.info
                local color = meta.color
                local icon  = meta.icon

                -- Enforce max lines
                if #self._entries >= maxLines then
                    local oldest = table.remove(self._entries, 1)
                    if oldest and oldest.frame and oldest.frame.Parent then
                        oldest.frame:Destroy()
                    end
                end

                local entry = Instance.new("Frame")
                entry.Name              = "Log_" .. self._count
                entry.Size              = UDim2.new(1, 0, 0, 0)
                entry.AutomaticSize     = Enum.AutomaticSize.Y
                entry.BackgroundTransparency = 1
                entry.LayoutOrder       = self._count
                entry.Parent            = (self._filter == nil or self._filter == level)
                    and scroll or nil

                local rowLayout = Instance.new("UIListLayout")
                rowLayout.FillDirection = Enum.FillDirection.Horizontal
                rowLayout.VerticalAlignment = Enum.VerticalAlignment.Center
                rowLayout.Padding       = UDim.new(0, 5)
                rowLayout.Parent        = entry

                -- Icon / level dot
                local iconLbl = U.Label(entry, icon, C.SmallSz, color, C.FontBold)
                iconLbl.Size            = UDim2.new(0, 10, 0, 16)
                iconLbl.LayoutOrder     = 1
                iconLbl.TextXAlignment  = Enum.TextXAlignment.Center
                iconLbl.TextTransparency= 0

                -- Tag badge
                if tag then
                    local tagLbl = U.Label(entry, "[" .. tag .. "]", C.TinySz, color, C.FontMono)
                    tagLbl.Size         = UDim2.new(0, 0, 0, 16)
                    tagLbl.AutomaticSize= Enum.AutomaticSize.X
                    tagLbl.LayoutOrder  = 2
                    tagLbl.TextXAlignment = Enum.TextXAlignment.Left
                end

                -- Message
                local msgLbl = U.Label(entry, message, C.SmallSz, T.Text, C.FontMono)
                msgLbl.Size             = UDim2.new(1, -90, 0, 0)
                msgLbl.AutomaticSize    = Enum.AutomaticSize.Y
                msgLbl.LayoutOrder      = 3

                -- Timestamp
                local tsLbl = U.Label(entry, U.Timestamp(), C.TinySz, T.TextDim, C.FontMono,
                    Enum.TextXAlignment.Right)
                tsLbl.Size              = UDim2.new(0, 55, 0, 16)
                tsLbl.LayoutOrder       = 4

                local record = {
                    frame   = entry,
                    level   = level,
                    message = message,
                    tag     = tag,
                    time    = U.Timestamp(),
                }
                table.insert(self._entries, record)

                scrollToBottom()
                return entry
            end

            -- Convenience shortcuts
            function logs:Info(msg, tag)    return self:Log(msg, "info",    tag) end
            function logs:Warn(msg, tag)    return self:Log(msg, "warn",    tag) end
            function logs:Error(msg, tag)   return self:Log(msg, "error",   tag) end
            function logs:Success(msg, tag) return self:Log(msg, "success", tag) end
            function logs:Debug(msg, tag)   return self:Log(msg, "debug",   tag) end
            function logs:System(msg, tag)  return self:Log(msg, "system",  tag) end
            function logs:Verbose(msg, tag) return self:Log(msg, "verbose", tag) end

            -- Clear
            function logs:Clear()
                for _, e in ipairs(self._entries) do
                    if e.frame and e.frame.Parent then
                        e.frame:Destroy()
                    end
                end
                self._entries = {}
                self._count   = 0
            end

            -- Filter (nil = show all, "error" = show only errors, etc.)
            function logs:SetFilter(level)
                self._filter = level
                for _, e in ipairs(self._entries) do
                    local show = (level == nil) or (e.level == level)
                    if show and not e.frame.Parent then
                        e.frame.Parent = scroll
                    elseif not show and e.frame.Parent then
                        e.frame.Parent = nil
                    end
                end
            end

            -- Export as string
            function logs:Export()
                local lines = {}
                for _, e in ipairs(self._entries) do
                    local tag = e.tag and ("[" .. e.tag .. "] ") or ""
                    table.insert(lines, string.format("[%s][%s] %s%s",
                        e.time, e.level:upper(), tag, e.message))
                end
                return table.concat(lines, "\n")
            end

            -- Wire buttons
            clearBtn.MouseButton1Click:Connect(function() logs:Clear() end)
            clearBtn.TouchTap:Connect(function() logs:Clear() end)

            local filterCycle = {nil, "info", "warn", "error", "success", "debug", "system"}
            local filterIdx = 1
            local filterNames = {"ALL", "INFO", "WARN", "ERR", "OK", "DBG", "SYS"}

            filterBtn.MouseButton1Click:Connect(function()
                filterIdx = (filterIdx % #filterCycle) + 1
                logs:SetFilter(filterCycle[filterIdx])
                filterBtn.Text = filterNames[filterIdx]
                local meta = filterCycle[filterIdx] and LEVELS[filterCycle[filterIdx]]
                filterBtn.TextColor3 = meta and meta.color or T.TextMuted
            end)
            filterBtn.TouchTap:Connect(function()
                filterIdx = (filterIdx % #filterCycle) + 1
                logs:SetFilter(filterCycle[filterIdx])
                filterBtn.Text = filterNames[filterIdx]
                local meta = filterCycle[filterIdx] and LEVELS[filterCycle[filterIdx]]
                filterBtn.TextColor3 = meta and meta.color or T.TextMuted
            end)

            return logs
        end  -- end AddLogs


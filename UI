		self:open()
	end)

	local function addHover(btn, holder, hoverColor, normalColor)
		btn.MouseEnter:Connect(function()
			tween(holder, TWEEN_FAST, { BackgroundColor3 = hoverColor })
		end)
		btn.MouseLeave:Connect(function()
			tween(holder, TWEEN_FAST, { BackgroundColor3 = normalColor })
		end)
	end
	addHover(closeBtn, closeBtnHolder, Color3.fromRGB(200, 60, 60), THEME.SurfaceLight)
	addHover(sendBtn, sendBtnHolder, Color3.fromRGB(130, 130, 220), THEME.Accent)

	inputBox.FocusLost:Connect(function(enter)
		if enter then self:_sendMessage() end
	end)
	sendBtn.MouseButton1Click:Connect(function()
		self:_sendMessage()
	end)

	self:log("System", "Autonomous UI initialised -- v" .. self._version, "info")

	return self
end

-- ─────────────────────────────────────────────────────────────
-- Tab Switching
-- ─────────────────────────────────────────────────────────────
function AutonomousUI:_switchTab(name)
	if self._activeTab == name then return end
	self._activeTab = name

	for tName, data in pairs(self._tabs) do
		local active = (tName == name)
		tween(data.indicator, TWEEN_MED, { BackgroundTransparency = active and 0 or 1 })
		tween(data.btn, TWEEN_FAST, { TextColor3 = active and THEME.TextPrimary or THEME.TextSecondary })
		data.btn.Font = active and Enum.Font.GothamBold or Enum.Font.Gotham
		self._tabFrames[tName].Visible = active
	end
end

-- ─────────────────────────────────────────────────────────────
-- Bubble Builder
-- ─────────────────────────────────────────────────────────────
function AutonomousUI:_buildBubble(parent, role, text, order)
	local isUser = (role == "You")

	local row = Instance.new("Frame")
	row.Size                  = UDim2.new(1, 0, 0, 0)
	row.AutomaticSize         = Enum.AutomaticSize.Y
	row.BackgroundTransparency = 1
	row.LayoutOrder           = order
	row.Parent                = parent

	local bubble = Instance.new("Frame")
	bubble.AutomaticSize    = Enum.AutomaticSize.Y
	bubble.Size             = UDim2.new(0.82, 0, 0, 0)
	bubble.Position         = isUser and UDim2.new(0.18, 0, 0, 0) or UDim2.new(0, 0, 0, 0)
	bubble.BackgroundColor3 = isUser and THEME.Accent or THEME.SurfaceLight
	bubble.BorderSizePixel  = 0
	bubble.Parent           = row
	makeCorner(bubble, 10)
	makePadding(bubble, 8, 10, 8, 10)

	if not isUser then
		makeStroke(bubble, THEME.Border, 1, 0.5)
		local nameTag = makeLabel(bubble, "Autonomous", 10, THEME.Accent, Enum.TextXAlignment.Left)
		nameTag.Font        = Enum.Font.GothamBold
		nameTag.Size        = UDim2.new(1, 0, 0, 14)
		nameTag.LayoutOrder = 0
	end

	local msgLabel = Instance.new("TextLabel")
	msgLabel.Text              = text
	msgLabel.TextSize          = 12
	msgLabel.TextColor3        = isUser and Color3.fromRGB(255, 255, 255) or THEME.TextPrimary
	msgLabel.Font              = Enum.Font.Gotham
	msgLabel.TextWrapped       = true
	msgLabel.TextXAlignment    = Enum.TextXAlignment.Left
	msgLabel.BackgroundTransparency = 1
	msgLabel.AutomaticSize    = Enum.AutomaticSize.Y
	msgLabel.Size             = UDim2.new(1, 0, 0, 0)
	msgLabel.LayoutOrder      = 1
	msgLabel.Parent           = bubble

	local bubbleLayout = Instance.new("UIListLayout")
	bubbleLayout.SortOrder = Enum.SortOrder.LayoutOrder
	bubbleLayout.Padding   = UDim.new(0, 4)
	bubbleLayout.Parent    = bubble

	bubble.BackgroundTransparency = 1
	msgLabel.TextTransparency     = 1
	tween(bubble,    TWEEN_MED, { BackgroundTransparency = 0 })
	tween(msgLabel,  TWEEN_MED, { TextTransparency = 0 })

	return row
end

-- ─────────────────────────────────────────────────────────────
-- Send Message
-- ─────────────────────────────────────────────────────────────
function AutonomousUI:_sendMessage()
	local text = self._inputBox.Text
	if not text or text:gsub("%s", "") == "" then return end
	self._inputBox.Text = ""

	local order = #self._messages + 1
	table.insert(self._messages, { role = "You", text = text, order = order })

	local chatFrame = self._tabFrames["Chat"]
	self:_buildBubble(chatFrame, "You", text, order)
	self:log("Chat", "You: " .. text, "info")

	if self.onMessage then
		local ok, err = pcall(self.onMessage, self, text)
		if not ok then
			self:log("Error", tostring(err), "error")
		end
	else
		-- ✅ Fixed: plain ASCII quotes only
		task.delay(0.6, function()
			self:reply('I received: "' .. text .. '"')
		end)
	end
end

-- ─────────────────────────────────────────────────────────────
-- Reply
-- ─────────────────────────────────────────────────────────────
function AutonomousUI:reply(text)
	local chatFrame = self._tabFrames["Chat"]
	local order = #self._messages + 1
	table.insert(self._messages, { role = "Autonomous", text = text, order = order })
	self:_buildBubble(chatFrame, "Autonomous", text, order)
	self:log("Chat", "Autonomous: " .. text, "info")

	task.defer(function()
		chatFrame.CanvasPosition = Vector2.new(0, chatFrame.AbsoluteCanvasSize.Y)
	end)
end

-- ─────────────────────────────────────────────────────────────
-- Logs
-- ─────────────────────────────────────────────────────────────
local LOG_COLORS = {
	info    = THEME.Info,
	success = THEME.Success,
	warning = THEME.Warning,
	error   = THEME.Error,
	system  = THEME.Accent,
}

function AutonomousUI:log(tag, message, level)
	level = level or "info"
	local color = LOG_COLORS[level] or THEME.TextSecondary
	local logsFrame = self._tabFrames["Logs"]
	local order = #self._logs + 1
	table.insert(self._logs, { tag = tag, message = message, level = level, order = order })

	local row = Instance.new("Frame")
	row.Size                  = UDim2.new(1, 0, 0, 0)
	row.AutomaticSize         = Enum.AutomaticSize.Y
	row.BackgroundColor3      = THEME.Surface
	row.BorderSizePixel       = 0
	row.LayoutOrder           = order
	row.Parent                = logsFrame
	makeCorner(row, 6)
	makePadding(row, 6, 8, 6, 8)
	makeStroke(row, THEME.Border, 1, 0.6)

	local rowLayout = Instance.new("UIListLayout")
	rowLayout.SortOrder = Enum.SortOrder.LayoutOrder
	rowLayout.Padding   = UDim.new(0, 2)
	rowLayout.Parent    = row

	local tagLabel = makeLabel(row, "[" .. tag:upper() .. "]", 10, color, Enum.TextXAlignment.Left)
	tagLabel.Font        = Enum.Font.GothamBold
	tagLabel.LayoutOrder = 0

	local msgLabel = Instance.new("TextLabel")
	msgLabel.Text              = message
	msgLabel.TextSize          = 11
	msgLabel.TextColor3        = THEME.TextSecondary
	msgLabel.Font              = Enum.Font.Gotham
	msgLabel.TextWrapped       = true
	msgLabel.TextXAlignment    = Enum.TextXAlignment.Left
	msgLabel.BackgroundTransparency = 1
	msgLabel.AutomaticSize     = Enum.AutomaticSize.Y
	msgLabel.Size              = UDim2.new(1, 0, 0, 0)
	msgLabel.LayoutOrder       = 1
	msgLabel.Parent            = row

	local ts = os.date("%H:%M:%S")
	local tsLabel = makeLabel(row, ts, 9, THEME.TextMuted, Enum.TextXAlignment.Right)
	tsLabel.LayoutOrder = 2

	task.defer(function()
		logsFrame.CanvasPosition = Vector2.new(0, logsFrame.AbsoluteCanvasSize.Y)
	end)
end

-- ─────────────────────────────────────────────────────────────
-- Open / Close
-- ─────────────────────────────────────────────────────────────
function AutonomousUI:close()
	if not self._isOpen then return end
	self._isOpen = false
	tween(self._window, TWEEN_MED, { Size = UDim2.new(0, 340, 0, 0) })
	task.delay(0.25, function()
		self._window.Visible    = false
		self._reopenBtn.Visible = true
	end)
	self:log("System", "UI closed", "system")
end

function AutonomousUI:open()
	if self._isOpen then return end
	self._isOpen            = true
	self._window.Visible    = true
	self._window.Size       = UDim2.new(0, 340, 0, 0)
	self._reopenBtn.Visible = false
	tween(self._window, TWEEN_MED, { Size = UDim2.new(0, 340, 0, 480) })
	self:log("System", "UI opened", "system")
end

-- ─────────────────────────────────────────────────────────────
-- Destroy
-- ─────────────────────────────────────────────────────────────
function AutonomousUI:destroy()
	self:log("System", "Destroying UI...", "warning")
	task.delay(0.3, function()
		self._screenGui:Destroy()
	end)
end

-- ─────────────────────────────────────────────────────────────
-- Getters
-- ─────────────────────────────────────────────────────────────
function AutonomousUI:getLogs()    return self._logs    end
function AutonomousUI:getHistory() return self._messages end
function AutonomousUI:isOpen()     return self._isOpen  end

return AutonomousUI

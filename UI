local NexusUI = {}
NexusUI.__index = NexusUI

function NexusUI.new(config)
    config = config or {}
    local self = setmetatable({}, NexusUI)

    -- Public config (future-proof slots)
    self.title        = config.title       or "NexusUI"
    self.subtitle     = config.subtitle    or "Chat Interface"
    self.width        = config.width       or (isMobile() and 340 or 420)
    self.height       = config.height      or (isMobile() and 500 or 560)
    self.maxLogs      = config.maxLogs     or 200
    self.placeholder  = config.placeholder or "Type a message..."
    self._messageCallback = nil   -- set via :OnMessage()
    self._aiHandler       = nil   -- future: set via :SetAIHandler()
    self._logEntries      = {}
    self._isOpen          = true
    self._isThinking      = false  -- future AI typing indicator

    self:_build()
    return self
end

-- ─────────────────────────────────────────────────────────────────────────────

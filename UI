    local vp     = workspace.CurrentCamera.ViewportSize
    local startX = math.floor((vp.X - self.width) / 2)
    local startY = math.floor((vp.Y - self.height) / 2)

    local win = Instance.new("Frame")
    win.Name             = "Window"
    win.Size             = UDim2.new(0, self.width, 0, self.height)
    win.Position         = UDim2.new(0, startX, 0, startY)
    win.BackgroundColor3 = THEME.bg
    win.BorderSizePixel  = 0
    win.ClipsDescendants = true
    win.Parent           = sg
    self._win = win

    applyCorner(win)
    applyStroke(win, THEME.border, 1.5)
    makeShadow(win)

    -- subtle gradient overlay on bg
    applyGradient(win,
        ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(18, 20, 30)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(10, 11, 16)),

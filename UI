function AutonomousUI:ApplyPreset(presetName)
    local preset = self.Presets[presetName]
    if not preset then
        warn("[AutonomousUI] Unknown preset: " .. tostring(presetName))
        return
    end
    for k, v in pairs(preset) do
        self.Theme[k] = v
    end
end

-- ─── Notification Toast ───────────────────────────────────────────────────────
-- Call anywhere after CreateWindow; renders over everything

function AutonomousUI:Notify(options)
    options = options or {}
    local T  = self.Theme
    local C  = self.Config

    local text  = options.Text    or "Notification"
    local level = (options.Level  or "info"):lower()
    local dur   = options.Duration or 3.5
    local title = options.Title

    local colors = {
        info    = T.Info,
        success = T.Success,
        warn    = T.Warning,
        error   = T.Error,
        system  = T.Accent,
    }
    local color = colors[level] or T.Info

    -- Find or create notify holder
    local holder = PlayerGui:FindFirstChild("AutonomousUI_Notifications")
    if not holder then
        holder = Instance.new("ScreenGui")
        holder.Name           = "AutonomousUI_Notifications"
        holder.ResetOnSpawn   = false
        holder.DisplayOrder   = 1001
        holder.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
        holder.Parent         = PlayerGui
    end

    -- Stack container
    local stack = holder:FindFirstChild("Stack")
    if not stack then
        stack = Instance.new("Frame")
        stack.Name              = "Stack"
        stack.Size              = UDim2.new(0, 260, 1, 0)
        stack.Position          = UDim2.new(1, -272, 0, 12)
        stack.BackgroundTransparency = 1
        stack.Parent            = holder
        U.ListLayout(stack, 8, Enum.FillDirection.Vertical,
            Enum.HorizontalAlignment.Center, Enum.VerticalAlignment.Top)
    end

    -- Toast frame
    local toast = Instance.new("Frame")
    toast.Size              = UDim2.new(1, 0, 0, 0)
    toast.AutomaticSize     = Enum.AutomaticSize.Y
    toast.BackgroundColor3  = T.Surface
    toast.BorderSizePixel   = 0
    toast.BackgroundTransparency = 1
    toast.ClipsDescendants  = true
    toast.Parent            = stack
    U.Corner(toast, C.InnerRadius)
    U.Stroke(toast, color, 1)
    U.Padding(toast, 10, 12, 10, 12)

    -- Color accent side bar
    local sideBar = Instance.new("Frame")
    sideBar.Size            = UDim2.new(0, 3, 1, 0)
    sideBar.BackgroundColor3= color
    sideBar.BorderSizePixel = 0
    sideBar.Parent          = toast
    U.Corner(sideBar, 2)

    if title then
        local titleLbl = U.Label(toast, title, C.SmallSz, color, C.FontBold)
        titleLbl.Size   = UDim2.new(1, -10, 0, 16)
        titleLbl.Position = UDim2.new(0, 10, 0, 0)
    end

    local msgLbl = U.Label(toast, text, C.SmallSz, T.Text, C.Font)
    msgLbl.Size     = UDim2.new(1, -10, 0, 0)
    msgLbl.AutomaticSize = Enum.AutomaticSize.Y
    msgLbl.Position = UDim2.new(0, 10, 0, title and 18 or 0)

    -- Slide in + fade
    U.Tween(toast, {BackgroundTransparency = 0}, 0.25)

    -- Auto dismiss
    task.delay(dur, function()
        U.Tween(toast, {BackgroundTransparency = 1}, 0.3)
        task.wait(0.35)
        toast:Destroy()
    end)

    return toast
end

